#
# tools/secrets - 基于 age 的本地密钥加密助手
#
# 加密流：  明文  ──age──>  dotfiles/secrets/<name>.age     (进 git)
# 解密流：  密文  ──age──>  $HOME/.local/share/secrets-decrypted/<name>  (不进 git)
#
# 设计原则：
#   - 私钥一律在 stow/secrets/.keys/age（不进 git，靠 stow 软链到 ~/.keys/age）
#   - 公钥在 dotfiles/secrets/.keys/age.pub（进 git，跨机部署用）
#   - 明文只在解密目标出现，使用方自己加载；本工具不主动改任何应用配置
#   - 所有命令都可加 --dry-run 做演练
#
# 用法：tools/secrets [--dry-run] <command> [args...]
#   init                       生成 age 密钥对（已存在则提示覆盖）
#   list                       列出所有 .age 密文 + 密钥文件状态
#   encrypt <name>             加密 stdin → dotfiles/secrets/<name>.age
#   decrypt <name>             解密 → ~/.local/share/secrets-decrypted/<name>（可加 --stdout）
#   edit <name>                解密到临时目录 → $EDITOR 编辑 → 回写密文
#   show <name>                解密后 cat 明文（小心贴到日志里）
#   recipients                 列出 dotfiles/secrets/.keys/ 下的所有公钥
#   re-encrypt [--with <key>]  用旧私钥解密所有 .age，用当前公钥重加密（轮换用）
#
# 环境变量：
#   SECRETS_PRIVATE_KEY   解密时指定的私钥路径（默认 ~/.keys/age）
#   SECRETS_PUBLIC_KEY    加密时指定的公钥路径（默认 dotfiles/secrets/.keys/age.pub）
#   EDITOR                edit 子命令用

set -euo pipefail

# 全局 dry-run 开关：1 时所有写副作用命令只打印计划不执行
DRY_RUN=0

# 仓库根：脚本在 tools/ 下，取父目录
REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
SECRETS_DIR="$REPO_ROOT/dotfiles/secrets"
PUB_KEY_DIR="$SECRETS_DIR/.keys"
DECRYPT_DIR="${XDG_DATA_HOME:-$HOME/.local/share}/secrets-decrypted"

# dry-run 守卫：被拦截时打印计划并返回 0（调用方 `plan ... && return 0/continue`）
plan() {
	[[ $DRY_RUN -eq 1 ]] && {
		echo "[dry-run] $*" >&2
		return 0
	}
	return 1
}

# 找第一个存在的公钥文件作为默认 recipient
find_default_pubkey() {
	if [[ -n "${SECRETS_PUBLIC_KEY:-}" && -f "${SECRETS_PUBLIC_KEY}" ]]; then
		echo "${SECRETS_PUBLIC_KEY}"
		return
	fi
	[[ -f "$PUB_KEY_DIR/age.pub" ]] && {
		echo "$PUB_KEY_DIR/age.pub"
		return
	}
	# 退化：任意 .pub
	local f
	f=$(find "$PUB_KEY_DIR" -maxdepth 1 -name '*.pub' -print -quit 2>/dev/null || true)
	[[ -n "$f" ]] && {
		echo "$f"
		return
	}
	return 1
}

# 找第一个存在的私钥文件
find_default_privkey() {
	if [[ -n "${SECRETS_PRIVATE_KEY:-}" && -f "${SECRETS_PRIVATE_KEY}" ]]; then
		echo "${SECRETS_PRIVATE_KEY}"
		return
	fi
	[[ -f "$HOME/.keys/age" ]] && {
		echo "$HOME/.keys/age"
		return
	}
	[[ -f "$REPO_ROOT/stow/secrets/.keys/age" ]] && {
		echo "$REPO_ROOT/stow/secrets/.keys/age"
		return
	}
	return 1
}

require_age() {
	if ! command -v age >/dev/null 2>&1; then
		echo "错误: 找不到 age 命令。请先 blue home 安装 age 包。" >&2
		exit 1
	fi
}

# 把 PUB_KEY_DIR 里所有 .pub 合并到 mktemp 文件并输出路径（无公钥时返回 1）
# cmd_encrypt 与 cmd_re_encrypt 共用，避免重复代码
collect_recipients() {
	local recipients_file
	recipients_file=$(mktemp)
	local f
	for f in "$PUB_KEY_DIR"/*.pub; do
		[[ -f "$f" ]] || continue
		cat "$f" >>"$recipients_file"
	done
	if [[ ! -s "$recipients_file" ]]; then
		rm -f "$recipients_file"
		return 1
	fi
	echo "$recipients_file"
}

cmd_init() {
	require_age
	if [[ -f "$REPO_ROOT/stow/secrets/.keys/age" ]]; then
		echo "已存在: $REPO_ROOT/stow/secrets/.keys/age"
		echo "如需覆盖请先 trash 现有私钥。"
		return 1
	fi
	plan "init: 生成密钥对 → $REPO_ROOT/stow/secrets/.keys/age + $PUB_KEY_DIR/age.pub" && return 0

	mkdir -p "$REPO_ROOT/stow/secrets/.keys" "$PUB_KEY_DIR"

	local priv="$REPO_ROOT/stow/secrets/.keys/age"
	local pub="$PUB_KEY_DIR/age.pub"
	age-keygen -o "$priv" 2>&1
	chmod 600 "$priv"

	# 从私钥首行注释提取公钥
	awk '/^# public key:/ {print $NF}' "$priv" >"$pub"
	chmod 644 "$pub"

	echo ""
	echo "✓ 私钥: $priv（不入 git）"
	echo "✓ 公钥: $pub（已纳入 dotfiles/secrets/，会进 git）"
	echo ""
	echo "下一步："
	echo "  1. cd $REPO_ROOT && blue stow secrets      # 部署私钥软链到 ~/.keys/age"
	echo "  2. tools/secrets encrypt <name> <plain.txt"
}

cmd_list() {
	echo "== 公钥（dotfiles/secrets/.keys/）=="
	if [[ -d "$PUB_KEY_DIR" ]]; then
		ls -la "$PUB_KEY_DIR/" 2>/dev/null | grep -v '^total\|^d' || echo "(无)"
	else
		echo "(目录不存在)"
	fi
	echo ""
	echo "== 私钥状态 =="
	local found=0
	for p in "${SECRETS_PRIVATE_KEY:-}" "$HOME/.keys/age" "$REPO_ROOT/stow/secrets/.keys/age"; do
		[[ -z "$p" ]] && continue
		if [[ -f "$p" ]]; then
			local mode
			mode=$(stat -c '%a' "$p" 2>/dev/null || stat -f '%Lp' "$p")
			echo "  ✓ $p (mode=$mode)"
			found=1
		fi
	done
	[[ $found -eq 0 ]] && echo "  (未找到任何私钥；先跑 init 或部署 stow/secrets)"
	echo ""
	echo "== 密文清单（dotfiles/secrets/*.age）=="
	if [[ -d "$SECRETS_DIR" ]]; then
		local f
		while IFS= read -r f; do
			local sz
			sz=$(stat -c '%s' "$f" 2>/dev/null || echo "?")
			printf "  %-40s %s bytes\n" "$f" "$sz"
		done < <(find "$SECRETS_DIR" -maxdepth 1 -name '*.age' -print 2>/dev/null | sort)
		if [[ -z "$(find "$SECRETS_DIR" -maxdepth 1 -name '*.age' -print -quit 2>/dev/null)" ]]; then
			echo "  (无)"
		fi
	else
		echo "(目录不存在)"
	fi
	echo ""
	echo "== 已解密的明文（$DECRYPT_DIR）=="
	if [[ -d "$DECRYPT_DIR" ]]; then
		find "$DECRYPT_DIR" -maxdepth 1 -type f -printf "  %f\n" 2>/dev/null | sort || echo "(无)"
		if [[ -z "$(find "$DECRYPT_DIR" -maxdepth 1 -type f -print -quit 2>/dev/null)" ]]; then
			echo "  (无)"
		fi
	else
		echo "(目录不存在，跑一次 decrypt 会自动创建)"
	fi
}

cmd_recipients() {
	if [[ ! -d "$PUB_KEY_DIR" ]]; then
		echo "无公钥目录: $PUB_KEY_DIR" >&2
		exit 1
	fi
	local f
	found=0
	for f in "$PUB_KEY_DIR"/*.pub; do
		[[ -f "$f" ]] || continue
		echo "# $(basename "$f")"
		cat "$f"
		echo ""
		found=1
	done
	[[ $found -eq 0 ]] && echo "(无 .pub 文件)"
}

cmd_encrypt() {
	require_age
	local name="${1:-}"
	if [[ -z "$name" ]]; then
		echo "用法: tools/secrets encrypt <name>" >&2
		echo "  从 stdin 读明文，写到 dotfiles/secrets/<name>.age" >&2
		exit 1
	fi
	local pub
	if ! pub=$(find_default_pubkey); then
		echo "错误: 找不到公钥。先跑 tools/secrets init。" >&2
		exit 1
	fi

	mkdir -p "$SECRETS_DIR"
	local out="$SECRETS_DIR/$name.age"
	if [[ -f "$out" ]]; then
		echo "警告: $out 已存在，将覆盖。" >&2
	fi

	# recipients file: 同一文件可被多个公钥解密时很有用
	local recipients_file
	if ! recipients_file=$(collect_recipients); then
		echo "错误: $PUB_KEY_DIR 里没有任何公钥。" >&2
		exit 1
	fi
	trap "rm -f '$recipients_file'" EXIT

	plan "encrypt: stdin → $out (recipients from $PUB_KEY_DIR)" && return 0
	age -R "$recipients_file" -o "$out"
	chmod 644 "$out"
	local sz
	sz=$(stat -c '%s' "$out" 2>/dev/null || stat -f '%z' "$out")
	echo "✓ 写入 $out ($sz bytes)，recipients: $(tr '\n' ' ' <"$recipients_file" | sed 's/ $//')"
}

cmd_decrypt() {
	require_age
	local name="${1:-}"
	local to_stdout=0
	[[ "${2:-}" == "--stdout" ]] && to_stdout=1

	if [[ -z "$name" ]]; then
		echo "用法: tools/secrets decrypt <name> [--stdout]" >&2
		exit 1
	fi
	local priv
	if ! priv=$(find_default_privkey); then
		echo "错误: 找不到私钥。" >&2
		echo "  候选路径: \$SECRETS_PRIVATE_KEY, ~/.keys/age, $REPO_ROOT/stow/secrets/.keys/age" >&2
		echo "  若都已 blue stow secrets 仍未生效，跑：cd $REPO_ROOT && blue stow secrets" >&2
		exit 1
	fi

	local cipher="$SECRETS_DIR/$name.age"
	if [[ ! -f "$cipher" ]]; then
		echo "错误: 密文不存在: $cipher" >&2
		exit 1
	fi

	if [[ $to_stdout -eq 1 ]]; then
		# 只读打印，dry-run 也允许查看
		age -d -i "$priv" "$cipher"
	else
		mkdir -p "$DECRYPT_DIR"
		local out="$DECRYPT_DIR/$name"
		if [[ -f "$out" ]]; then
			echo "警告: $out 已存在，将覆盖。" >&2
		fi
		plan "decrypt: $cipher → $out" && return 0
		age -d -i "$priv" -o "$out" "$cipher"
		chmod 600 "$out"
		echo "✓ 解密到 $out"
	fi
}

cmd_show() {
	cmd_decrypt "$1" --stdout
}

cmd_edit() {
	local name="${1:-}"
	if [[ -z "$name" ]]; then
		echo "用法: tools/secrets edit <name>" >&2
		exit 1
	fi
	: "${EDITOR:=nano}"
	if ! command -v "$EDITOR" >/dev/null 2>&1; then
		echo "错误: EDITOR='$EDITOR' 不可用" >&2
		exit 1
	fi

	local cipher="$SECRETS_DIR/$name.age"
	local priv
	priv=$(find_default_privkey) || {
		echo "错误: 找不到私钥" >&2
		exit 1
	}

	plan "edit: $name（解密 → $EDITOR → 回写密文）" && return 0

	# 隔离目录：明文 + 编辑器副产物（backup~/#autosave#）都落在内，整体清理
	# RETURN 陷阱在任意函数返回时都会触发（含 cmd_edit 内部调用的 cmd_encrypt），
	# 故用 ${tmpdir:-} 守卫，避免 set -u 下其它函数返回时报未绑定变量
	local tmpdir tmp
	tmpdir=$(mktemp -d)
	trap '[[ -n "${tmpdir:-}" ]] && rm -rf "$tmpdir"' RETURN INT TERM
	tmp="$tmpdir/plaintext"
	# mktemp 创建时权限 600
	if [[ -f "$cipher" ]]; then
		age -d -i "$priv" "$cipher" >"$tmp"
	else
		echo "提示: $cipher 不存在，将从空模板开始。" >&2
		: >"$tmp"
	fi

	if ! "$EDITOR" "$tmp"; then
		echo "错误: 编辑器退出码非零，未写回密文。" >&2
		exit 1
	fi

	# 若文件为空且原密文不存在，给个清晰退出
	if [[ ! -s "$tmp" ]] && [[ ! -f "$cipher" ]]; then
		echo "未修改（空文件），未生成密文。" >&2
		exit 1
	fi

	# 用 cmd_encrypt 的逻辑回写
	cmd_encrypt "$name" <"$tmp"
}

cmd_re_encrypt() {
	require_age
	local decrypt_key=""
	while [[ $# -gt 0 ]]; do
		case "$1" in
		--with)
			[[ $# -lt 2 ]] && {
				echo "错误: --with 需要一个参数" >&2
				exit 1
			}
			decrypt_key="$2"
			shift 2
			;;
		*)
			echo "未知参数: $1" >&2
			echo "用法: tools/secrets re-encrypt [--with <old-private-key>]" >&2
			exit 1
			;;
		esac
	done

	if [[ -z "$decrypt_key" ]]; then
		if ! decrypt_key=$(find_default_privkey); then
			echo "错误: 未指定 --with，且默认私钥也不存在。" >&2
			exit 1
		fi
	elif [[ ! -f "$decrypt_key" ]]; then
		echo "错误: --with 指定的私钥不存在: $decrypt_key" >&2
		exit 1
	fi

	local pub
	if ! pub=$(find_default_pubkey); then
		echo "错误: 找不到公钥。" >&2
		exit 1
	fi

	local recipients_file
	if ! recipients_file=$(collect_recipients); then
		echo "错误: $PUB_KEY_DIR 里没有任何公钥。" >&2
		exit 1
	fi
	trap "rm -f '$recipients_file'" EXIT

	local cipher name
	while IFS= read -r cipher; do
		name="$(basename "$cipher")"
		name="${name%.age}"
		plan "re-encrypt: $name (decrypt: $decrypt_key, encrypt: $pub)" && continue
		# 解密失败（pipefail）会让整个脚本中止，避免部分轮换
		age -d -i "$decrypt_key" "$cipher" | age -R "$recipients_file" -o "$cipher.tmp" &&
			mv "$cipher.tmp" "$cipher"
		echo "✓ 重加密 $name"
	done < <(find "$SECRETS_DIR" -maxdepth 1 -name '*.age' -print 2>/dev/null | sort)
}

usage() {
	cat <<'EOF'
用法：tools/secrets [--dry-run] <command> [args...]

命令：
  init                       生成 age 密钥对（已存在则提示覆盖）
  list                       列出所有 .age 密文 + 密钥文件状态
  encrypt <name>             加密 stdin → dotfiles/secrets/<name>.age
  decrypt <name>             解密 → $XDG_DATA_HOME/secrets-decrypted/<name>
                             （可加 --stdout 直接打印）
  edit <name>                解密到临时目录 → $EDITOR 编辑 → 回写密文
  show <name>                解密后 cat 明文（= decrypt --stdout）
  recipients                 列出 dotfiles/secrets/.keys/ 下的所有公钥
  re-encrypt [--with <key>]  用旧私钥解密所有 .age，用当前公钥重加密（轮换用）

环境变量：
  SECRETS_PRIVATE_KEY        解密时指定的私钥路径（默认 ~/.keys/age）
  SECRETS_PUBLIC_KEY         加密时指定的公钥路径（默认 dotfiles/secrets/.keys/age.pub）
  EDITOR                     edit 子命令用

全局选项：
  --dry-run                  只打印将执行的操作，不实际写盘（须置于命令之前）
EOF
	exit 1
}

main() {
	if [[ "${1:-}" == "--dry-run" ]]; then
		DRY_RUN=1
		shift
	fi
	local cmd="${1:-}"
	shift || true
	case "$cmd" in
	init) cmd_init "$@" ;;
	list | ls) cmd_list "$@" ;;
	recipients) cmd_recipients "$@" ;;
	encrypt) cmd_encrypt "$@" ;;
	decrypt) cmd_decrypt "$@" ;;
	show) cmd_show "$@" ;;
	edit) cmd_edit "$@" ;;
	re-encrypt) cmd_re_encrypt "$@" ;;
	-h | --help | help | "") usage ;;
	*)
		echo "未知命令: $cmd" >&2
		usage
		;;
	esac
}

main "$@"
