# tools/secrets - 基于 age 的本地密钥加密助手
#
# 加密流：  明文  ──age──>  dotfiles/secrets/<name>.age     (进 git)
# 解密流：  密文  ──age──>  $HOME/.local/share/secrets-decrypted/<name>  (不进 git)
#
# 设计原则：
#   - 私钥一律在 stow/secrets/.keys/age（不进 git，靠 stow 软链到 ~/.keys/age）
#   - 公钥在 dotfiles/secrets/.keys/age.pub（进 git，跨机部署用）
#   - 明文只在解密目标出现，使用方自己加载；本工具不主动改任何应用配置
#   - 所有命令都可加 --dry-run 做演练
#
# 用法：tools/secrets <command> [args...]
#   init              生成 age 密钥对（已存在则提示覆盖）
#   list              列出所有 .age 密文 + 密钥文件状态
#   encrypt <name>    加密 stdin → dotfiles/secrets/<name>.age
#   decrypt <name>    解密 → ~/.local/share/secrets-decrypted/<name>（可加 --stdout）
#   edit <name>       解密到临时文件 → $EDITOR 编辑 → 回写密文
#   show <name>       解密后 cat 明文（小心贴到日志里）
#   recipients        列出 dotfiles/secrets/.keys/ 下的所有公钥
#
# 环境变量：
#   SECRETS_PRIVATE_KEY   解密时指定的私钥路径（默认 ~/.keys/age）
#   SECRETS_PUBLIC_KEY    加密时指定的公钥路径（默认 dotfiles/secrets/.keys/age.pub）
#   EDITOR                edit 子命令用

set -euo pipefail

# 仓库根：脚本在 tools/ 下，取父目录
REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
SECRETS_DIR="$REPO_ROOT/dotfiles/secrets"
PUB_KEY_DIR="$SECRETS_DIR/.keys"
DECRYPT_DIR="${XDG_DATA_HOME:-$HOME/.local/share}/secrets-decrypted"

# 找第一个存在的公钥文件作为默认 recipient
find_default_pubkey() {
    [[ -f "$PUB_KEY_DIR/age.pub" ]] && { echo "$PUB_KEY_DIR/age.pub"; return; }
    # 退化：任意 .pub
    local f
    f=$(find "$PUB_KEY_DIR" -maxdepth 1 -name '*.pub' -print -quit 2>/dev/null || true)
    [[ -n "$f" ]] && { echo "$f"; return; }
    return 1
}

# 找第一个存在的私钥文件
find_default_privkey() {
    if [[ -n "${SECRETS_PRIVATE_KEY:-}" && -f "${SECRETS_PRIVATE_KEY}" ]]; then
        echo "${SECRETS_PRIVATE_KEY}"; return
    fi
    [[ -f "$HOME/.keys/age" ]] && { echo "$HOME/.keys/age"; return; }
    [[ -f "$REPO_ROOT/stow/secrets/.keys/age" ]] && {
        echo "$REPO_ROOT/stow/secrets/.keys/age"; return;
    }
    return 1
}

require_age() {
    if ! command -v age >/dev/null 2>&1; then
        echo "错误: 找不到 age 命令。请先 blue home 安装 age 包。" >&2
        exit 1
    fi
}

cmd_init() {
    require_age
    if [[ -f "$REPO_ROOT/stow/secrets/.keys/age" ]]; then
        echo "已存在: $REPO_ROOT/stow/secrets/.keys/age"
        echo "如需覆盖请先 trash 现有私钥。"
        return 1
    fi
    mkdir -p "$REPO_ROOT/stow/secrets/.keys" "$PUB_KEY_DIR"

    local priv="$REPO_ROOT/stow/secrets/.keys/age"
    local pub="$PUB_KEY_DIR/age.pub"
    age-keygen -o "$priv" 2>&1
    chmod 600 "$priv"

    # 从私钥首行注释提取公钥
    awk '/^# public key:/ {print $NF}' "$priv" > "$pub"
    chmod 644 "$pub"

    echo ""
    echo "✓ 私钥: $priv（不入 git）"
    echo "✓ 公钥: $pub（已纳入 dotfiles/secrets/，会进 git）"
    echo ""
    echo "下一步："
    echo "  1. cd $REPO_ROOT && blue stow secrets      # 部署私钥软链到 ~/.keys/age"
    echo "  2. tools/secrets encrypt <name> <plain.txt"
}

cmd_list() {
    echo "== 公钥（dotfiles/secrets/.keys/）=="
    if [[ -d "$PUB_KEY_DIR" ]]; then
        ls -la "$PUB_KEY_DIR/" 2>/dev/null | grep -v '^total\|^d' || echo "(无)"
    else
        echo "(目录不存在)"
    fi
    echo ""
    echo "== 私钥状态 =="
    local found=0
    for p in "${SECRETS_PRIVATE_KEY:-}" "$HOME/.keys/age" "$REPO_ROOT/stow/secrets/.keys/age"; do
        [[ -z "$p" ]] && continue
        if [[ -f "$p" ]]; then
            local mode
            mode=$(stat -c '%a' "$p" 2>/dev/null || stat -f '%Lp' "$p")
            echo "  ✓ $p (mode=$mode)"
            found=1
        fi
    done
    [[ $found -eq 0 ]] && echo "  (未找到任何私钥；先跑 init 或部署 stow/secrets)"
    echo ""
    echo "== 密文清单（dotfiles/secrets/*.age）=="
    if [[ -d "$SECRETS_DIR" ]]; then
        local f
        while IFS= read -r f; do
            local sz
            sz=$(stat -c '%s' "$f" 2>/dev/null || echo "?")
            printf "  %-40s %s bytes\n" "$f" "$sz"
        done < <(find "$SECRETS_DIR" -maxdepth 1 -name '*.age' -print 2>/dev/null | sort)
        if [[ -z "$(find "$SECRETS_DIR" -maxdepth 1 -name '*.age' -print -quit 2>/dev/null)" ]]; then
            echo "  (无)"
        fi
    else
        echo "(目录不存在)"
    fi
    echo ""
    echo "== 已解密的明文（$DECRYPT_DIR）=="
    if [[ -d "$DECRYPT_DIR" ]]; then
        find "$DECRYPT_DIR" -maxdepth 1 -type f -printf "  %f\n" 2>/dev/null | sort || echo "(无)"
        if [[ -z "$(find "$DECREPT_DIR" -maxdepth 1 -type f -print -quit 2>/dev/null)" ]]; then
            echo "  (无)"
        fi
    else
        echo "(目录不存在，跑一次 decrypt 会自动创建)"
    fi
}

cmd_recipients() {
    if [[ ! -d "$PUB_KEY_DIR" ]]; then
        echo "无公钥目录: $PUB_KEY_DIR" >&2
        exit 1
    fi
    local f
    found=0
    for f in "$PUB_KEY_DIR"/*.pub; do
        [[ -f "$f" ]] || continue
        echo "# $(basename "$f")"
        cat "$f"
        echo ""
        found=1
    done
    [[ $found -eq 0 ]] && echo "(无 .pub 文件)"
}

cmd_encrypt() {
    require_age
    local name="${1:-}"
    if [[ -z "$name" ]]; then
        echo "用法: tools/secrets encrypt <name>" >&2
        echo "  从 stdin 读明文，写到 dotfiles/secrets/<name>.age" >&2
        exit 1
    fi
    local pub
    if ! pub=$(find_default_pubkey); then
        echo "错误: 找不到公钥。先跑 tools/secrets init。" >&2
        exit 1
    fi

    mkdir -p "$SECRETS_DIR"
    local out="$SECRETS_DIR/$name.age"
    if [[ -f "$out" ]]; then
        echo "警告: $out 已存在，将覆盖。" >&2
    fi

    # recipients file: 同一文件可被多个公钥解密时很有用
    local recipients_file
    recipients_file=$(mktemp)
    trap "rm -f '$recipients_file'" EXIT

    # 把 PUB_KEY_DIR 里所有 .pub 收进来当 recipients
    local f
    for f in "$PUB_KEY_DIR"/*.pub; do
        [[ -f "$f" ]] || continue
        cat "$f" >> "$recipients_file"
    done

    if [[ ! -s "$recipients_file" ]]; then
        echo "错误: $PUB_KEY_DIR 里没有任何公钥。" >&2
        exit 1
    fi

    age -R "$recipients_file" -o "$out"
    chmod 644 "$out"
    local sz
    sz=$(stat -c '%s' "$out" 2>/dev/null || stat -f '%z' "$out")
    echo "✓ 写入 $out ($sz bytes)，recipients: $(tr '\n' ' ' < "$recipients_file" | sed 's/ $//')"
}

cmd_decrypt() {
    require_age
    local name="${1:-}"
    local to_stdout=0
    [[ "${2:-}" == "--stdout" ]] && to_stdout=1

    if [[ -z "$name" ]]; then
        echo "用法: tools/secrets decrypt <name> [--stdout]" >&2
        exit 1
    fi
    local priv
    if ! priv=$(find_default_privkey); then
        echo "错误: 找不到私钥。" >&2
        echo "  候选路径: \$SECRETS_PRIVATE_KEY, ~/.keys/age, $REPO_ROOT/stow/secrets/.keys/age" >&2
        echo "  若都已 blue stow secrets 仍未生效，跑：cd $REPO_ROOT && blue stow secrets" >&2
        exit 1
    fi

    local cipher="$SECRETS_DIR/$name.age"
    if [[ ! -f "$cipher" ]]; then
        echo "错误: 密文不存在: $cipher" >&2
        exit 1
    fi

    if [[ $to_stdout -eq 1 ]]; then
        age -d -i "$priv" "$cipher"
    else
        mkdir -p "$DECRYPT_DIR"
        local out="$DECRYPT_DIR/$name"
        if [[ -f "$out" ]]; then
            echo "警告: $out 已存在，将覆盖。" >&2
        fi
        age -d -i "$priv" -o "$out" "$cipher"
        chmod 600 "$out"
        echo "✓ 解密到 $out"
    fi
}

cmd_show() {
    cmd_decrypt "$1" --stdout
}

cmd_edit() {
    local name="${1:-}"
    if [[ -z "$name" ]]; then
        echo "用法: tools/secrets edit <name>" >&2
        exit 1
    fi
    : "${EDITOR:=nano}"
    if ! command -v "$EDITOR" >/dev/null 2>&1; then
        echo "错误: EDITOR='$EDITOR' 不可用" >&2
        exit 1
    fi

    local cipher="$SECRETS_DIR/$name.age"
    local priv
    priv=$(find_default_privkey) || { echo "错误: 找不到私钥" >&2; exit 1; }

    local tmp
    tmp=$(mktemp)
    # mktemp 创建时权限 600
    if [[ -f "$cipher" ]]; then
        age -d -i "$priv" "$cipher" > "$tmp"
    else
        echo "提示: $cipher 不存在，将从空模板开始。" >&2
        : > "$tmp"
    fi

    if ! "$EDITOR" "$tmp"; then
        echo "错误: 编辑器退出码非零，未写回密文。" >&2
        rm -f "$tmp"
        exit 1
    fi

    # 若文件为空且原密文不存在，给个清晰退出
    if [[ ! -s "$tmp" ]] && [[ ! -f "$cipher" ]]; then
        echo "未修改（空文件），未生成密文。" >&2
        rm -f "$tmp"
        exit 1
    fi

    # 用 cmd_encrypt 的逻辑回写
    cmd_encrypt "$name" < "$tmp"
    rm -f "$tmp"
}

usage() {
    sed -n '2,/^set -euo pipefail/p' "$0" | sed '$d'
    exit 1
}

main() {
    local cmd="${1:-}"
    shift || true
    case "$cmd" in
        init)        cmd_init "$@" ;;
        list|ls)     cmd_list "$@" ;;
        recipients)  cmd_recipients "$@" ;;
        encrypt)     cmd_encrypt "$@" ;;
        decrypt)     cmd_decrypt "$@" ;;
        show)        cmd_show "$@" ;;
        edit)        cmd_edit "$@" ;;
        -h|--help|help|"") usage ;;
        *) echo "未知命令: $cmd" >&2; usage ;;
    esac
}

main "$@"