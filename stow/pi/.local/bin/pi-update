#!/usr/bin/env bash
# SPDX-FileCopyrightText: 2026 BrokenShine <xchai404@gmail.com>
#
# SPDX-License-Identifier: MIT
set -euo pipefail

# --extensions-only: 首次安装时由 pi 脚本调用，只装扩展、跳过核心更新和 native rebuild
EXTENSIONS_ONLY=0
if [[ "${1:-}" == "--extensions-only" ]]; then
	EXTENSIONS_ONLY=1
	shift
fi

PI_DATA_DIR="${PI_LOCAL_ROOT:-${XDG_DATA_HOME:-${HOME}/.local/share}/pi}"
PI_CONFIG_DIR="${PI_CODING_AGENT_DIR:-${XDG_CONFIG_HOME:-${HOME}/.config}/pi}"
EXT_DIR="${PI_CONFIG_DIR}/npm"
SETTINGS_FILE="${PI_CONFIG_DIR}/settings.json"
PI_BIN="${PI_DATA_DIR}/node_modules/.bin/pi"

# 缺了任一 binding 会导致 pi 启动崩溃
NATIVE_PKGS=(better-sqlite3 koffi)

# 不应自动移除的核心/框架包（settings.json 未列出时保留）
PROTECTED_PKGS=(pi-subagents)

# 顶层无条件声明：--extensions-only 模式跳过 native rebuild 时，
# FAILED 数组仍已声明，set -u 下引用 ${#FAILED[@]} 安全
FAILED=()

if ! command -v pnpm &>/dev/null; then
	echo "pnpm is not installed." >&2
	exit 1
fi

if [[ ! -x "${PI_BIN}" ]]; then
	echo "Pi core not installed at ${PI_DATA_DIR}; running pnpm install first..." >&2
	(cd "${PI_DATA_DIR}" && CI=true pnpm install --no-frozen-lockfile)
fi

# === package.json 缺失时从 settings.json + lockfile 自动 bootstrap ===
# 设计：package.json 是 settings.json 的派生产物，不手维护。
# settings.json 的 packages 列表是单一真相源；版本号优先取 lockfile 现存
# specifier（保留精确版本），缺失才 fallback 到 latest。
bootstrap_extensions_package() {
	[[ -f "${EXT_DIR}/package.json" ]] && return
	[[ -d "${EXT_DIR}" ]] || mkdir -p "${EXT_DIR}"
	echo "  package.json 缺失，从 settings.json + lockfile 重建..." >&2

	local lockfile="${EXT_DIR}/pnpm-lock.yaml"
	node -e '
		const fs = require("fs");
		const [settingsFile, lockFile, outFile] = process.argv.slice(1);
		const cfg = JSON.parse(fs.readFileSync(settingsFile, "utf8"));

		// 从 lockfile importers 段提取现存 specifier
		const specs = {};
		if (fs.existsSync(lockFile)) {
			const lock = fs.readFileSync(lockFile, "utf8");
			const i = lock.indexOf("importers:");
			const j = lock.indexOf("\npackages:", i);
			const block = lock.slice(i, j > 0 ? j : lock.length);
			const re = /^      \x27?([^:^\x27\n]+)\x27?:\n        specifier: (\S+)/gm;
			let m; while ((m = re.exec(block))) specs[m[1]] = m[2];
		}

		// 以 settings.json 的 npm: 包为真相源
		const deps = {};
		for (const p of (cfg.packages || [])) {
			if (!p.startsWith("npm:")) continue;
			const name = p.slice(4);
			deps[name] = specs[name] || "latest";
		}

		// 注意：不写 package.json 的 pnpm 字段——pnpm 10+ 已废弃该字段并 warning。
		// onlyBuiltDependencies 改由同目录 pnpm-workspace.yaml 配置（见函数末尾）。
		fs.writeFileSync(outFile, JSON.stringify({
			name: "pi-extensions",
			private: true,
			type: "module",
			dependencies: deps
		}, null, 2) + "\n");
	' "${SETTINGS_FILE}" "${lockfile}" "${EXT_DIR}/package.json"

	# pnpm 10+ 的 onlyBuiltDependencies 配置位置（与 .local/share/pi 的语义保持一致）
	local wsfile="${EXT_DIR}/pnpm-workspace.yaml"
	if [[ ! -f "${wsfile}" ]]; then
		cat >"${wsfile}" <<'EOF'
# pnpm 10+ 配置：package.json 的 pnpm 字段已废弃，改用此文件
onlyBuiltDependencies:
  - "@google/genai"
  - protobufjs
EOF
	fi
}

bootstrap_extensions_package

# === 从 settings.json 同步扩展包清单 ===
sync_extensions_from_settings() {
	[[ -f "${SETTINGS_FILE}" ]] || {
		echo "  settings.json 不存在，跳过" >&2
		return
	}

	local diff
	diff=$(node -e '
		const fs = require("fs");
		const [settingsFile, pkgFile, ...protect] = process.argv.slice(1);
		const cfg = JSON.parse(fs.readFileSync(settingsFile, "utf8"));
		const pkg = JSON.parse(fs.readFileSync(pkgFile, "utf8"));

		const desired = (cfg.packages || [])
			.filter(p => p.startsWith("npm:"))
			.map(p => p.slice(4));
		const current = Object.keys(pkg.dependencies || {});

		const add = desired.filter(p => !current.includes(p));
		const rem = current.filter(p =>
			!desired.includes(p) &&
			!p.startsWith("@earendil-works/") &&
			!protect.includes(p)
		);

		if (add.length) process.stdout.write("add:" + add.join(" ") + "\n");
		if (rem.length) process.stdout.write("remove:" + rem.join(" ") + "\n");
	' "${SETTINGS_FILE}" "${EXT_DIR}/package.json" "${PROTECTED_PKGS[@]}")

	if [[ -z "${diff}" ]]; then
		echo "  无需变更"
		return
	fi

	while IFS= read -r line; do
		case "${line}" in
		add:*)
			local pkgs="${line#add:}"
			echo "  安装: ${pkgs}"
			(cd "${EXT_DIR}" && pnpm add ${pkgs} 2>&1)
			;;
		remove:*)
			local pkgs="${line#remove:}"
			echo "  移除: ${pkgs}"
			(cd "${EXT_DIR}" && pnpm remove ${pkgs} 2>&1)
			;;
		esac
	done <<<"${diff}"
}

read_pi_version() {
	node -p "require('${PI_DATA_DIR}/node_modules/@earendil-works/pi-coding-agent/package.json').version" 2>/dev/null || echo '未知'
}

# pnpm 11 以 ERR_PNPM_IGNORED_BUILDS 退出码 1 标记未审批的 build scripts，
# 但包本身已正常安装。只对真正的 store 冲突或解析失败走重装。
pnpm_update_or_reinstall() {
	local dir="$1" label="$2"
	local out
	out=$(cd "${dir}" && pnpm update 2>&1) || {
		if echo "${out}" | grep -q 'ERR_PNPM_UNEXPECTED_STORE'; then
			echo "[${label}] store 版本不兼容，重新安装..." >&2
			(cd "${dir}" && CI=true pnpm install --no-frozen-lockfile 2>&1)
		elif echo "${out}" | grep -q 'ERR_PNPM_IGNORED_BUILDS'; then
			echo "${out}" | grep -v 'ERR_PNPM_IGNORED_BUILDS' | grep -v 'Run "pnpm approve-builds"'
			echo "[${label}] 部分依赖需要审批 build scripts（非致命）"
		else
			echo "${out}"
			echo "[${label}] pnpm update 失败，重新安装..." >&2
			(cd "${dir}" && CI=true pnpm install --no-frozen-lockfile 2>&1)
		fi
		return
	}
	echo "${out}"
}

echo "当前版本: $(read_pi_version)"

if [[ ${EXTENSIONS_ONLY} -eq 0 ]]; then
	echo "更新 Pi 核心..."
	pnpm_update_or_reinstall "${PI_DATA_DIR}" "Pi 核心"
fi

echo "同步扩展包（依据 settings.json）..."
sync_extensions_from_settings

echo "更新扩展..."
pnpm_update_or_reinstall "${EXT_DIR}" "扩展"

if [[ ${EXTENSIONS_ONLY} -eq 0 ]]; then
	# prebuild-install 偶发 silent 失败; 强制 rebuild + 验证 binding 实际存在
	echo "重建 native binding..."
	shopt -s nullglob
	for pkg in "${NATIVE_PKGS[@]}"; do
		printf "  %s ... " "${pkg}"
		if ! (cd "${EXT_DIR}" && pnpm rebuild "${pkg}" >/dev/null 2>&1); then
			echo "rebuild 失败"
			FAILED+=("${pkg}")
			continue
		fi
		# pnpm 把 / 转成 + (@google/genai -> @google+genai), 用通配找 .node
		pnpm_name="${pkg//\//+}"
		found=0
		for d in "${EXT_DIR}/node_modules/.pnpm/${pnpm_name}@"*; do
			if find "$d" -name '*.node' 2>/dev/null | grep -q .; then
				found=1
				break
			fi
		done
		if [[ $found -eq 1 ]]; then
			echo "OK"
		else
			echo "binding 缺失!"
			FAILED+=("${pkg}")
		fi
	done
fi

echo ""
echo "更新后: $(read_pi_version)"
if [[ ${#FAILED[@]} -gt 0 ]]; then
	echo "失败: ${FAILED[*]}" >&2
	exit 1
fi
echo "提示: 已运行的 pi 进程仍用旧版本,需重启 pi 加载新代码"
