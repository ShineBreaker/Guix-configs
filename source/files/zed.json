{
  "cli_default_open_behavior": "existing_window",
  "ui_font_family": "Sarasa UI SC",
  "buffer_font_family": "Maple Mono NF CN",
  "agent_servers": {
    "opencode": {
      "type": "registry"
    },
    "pi-acp": {
      "type": "registry"
    }
  },
  "theme": {
    "mode": "system",
    "light": "One Light",
    "dark": "One Dark"
  },
  "language_models": {
    "opencode": {
      "show_zen_models": false
    }
  },
  "active_pane_modifiers": {
    "border_size": 2.0,
    "inactive_opacity": 0.8
  },
  "agent": {
    "dock": "right",
    "default_model": {
      "provider": "opencode",
      "model": "go/glm-5.1",
      "enable_thinking": true
    },
    "model_parameters": [],
    "play_sound_when_agent_done": "always",
    "tool_permissions": {
      "default": "allow"
    }
  },
  "auto_install_extensions": {
    "astro": true,
    "basher": true,
    "catppuccin-icons": true,
    "colorizer": true,
    "csharp": true,
    "elisp": true,
    "fish": true,
    "git-firefly": true,
    "html": true,
    "java": true,
    "kdl": true,
    "kotlin": true,
    "log": true,
    "make": true,
    "neocmake": true,
    "nix": true,
    "python": true,
    "scheme": true,
    "scss": true,
    "sinppets": true,
    "toml": true,
    "xml": true,
    "zig": true
  },
  "auto_signature_help": true,
  "auto_update": false,
  "autosave": "on_focus_change",
  "autoscroll_on_clicks": false,
  "base_keymap": "VSCode",
  "buffer_font_size": 14,
  "buffer_font_weight": 400.0,
  "collaboration_panel": {
    "dock": "left",
    "button": false
  },
  "current_line_highlight": "all",
  "cursor_shape": "bar",
  "diagnostics": {
    "inline": {
      "enabled": true
    },
    "lsp_pull_diagnostics": {
      "debounce_ms": 100
    }
  },
  "disable_ai": false,
  "format_on_save": "on",
  "git": {
    "git_gutter": "tracked_files",
    "inline_blame": {
      "delay_ms": 2000,
      "enabled": true,
      "show_commit_summary": true
    }
  },
  "git_panel": {
    "button": true,
    "dock": "left"
  },
  "icon_theme": "Catppuccin Frappé",
  "inlay_hints": {
    "enabled": true,
    "show_background": false
  },
  "languages": {
    "C": {
      "language_servers": ["ccls"],
      "formatter": {
        "external": {
          "command": "$$bin/clang-format$$",
          "arguments": ["-style=file", "-assume-filename={buffer_path}"]
        }
      }
    },
    "C++": {
      "language_servers": ["ccls"],
      "formatter": {
        "external": {
          "command": "$$bin/clang-format$$",
          "arguments": ["-style=file", "-assume-filename={buffer_path}"]
        }
      }
    },
    "Java": {
      "language_servers": ["jdtls"]
    },
    "JSON": {
      "formatter": {
        "external": {
          "command": "$$bin/js-beautify$$",
          "arguments": ["--stdin", "--indent-size", "2", "-"]
        }
      }
    },
    "JSONC": {
      "soft_wrap": "prefer_line",
      "formatter": {
        "external": {
          "command": "$$bin/js-beautify$$",
          "arguments": ["--stdin", "--indent-size", "2", "-"]
        }
      }
    },
    "Python": {
      "language_servers": [
        "pylsp",
        "!pyright",
        "!ruff",
        "!basedpyright",
        "!pylsp"
      ],
      "formatter": {
        "external": {
          "command": "$$bin/black$$",
          "arguments": ["--quiet", "--stdin-filename", "{buffer_path}", "-"]
        }
      }
    }
  },
  "lsp": {
    "ccls": {
      "binary": {
        "path": "$$bin/ccls$$"
      }
    },
    "jdtls": {
      "binary": {
        "path": "$$bin/jdtls$$"
      }
    },
    "kotlin-language-server": {
      "settings": {
        "compiler": {
          "jvm": {
            "target": "25"
          }
        }
      }
    },
    "package-version-server": {
      "binary": {
        "path": "$$bin/package-version-server$$"
      }
    },
    "pylsp": {
      "binary": {
        "path": "$$bin/pylsp$$"
      },
      "initialization_options": {
        "pylsp": {
          "plugins": {
            "black": {
              "enabled": true
            },
            "mypy": {
              "enabled": true
            },
            "rope": {
              "enabled": true
            }
          }
        }
      }
    },
    "rust-analyzer": {
      "binary": {
        "path": "$$bin/rust-analyzer$$"
      }
    }
  },
  "node": {
    "path": "$$bin/node$$",
    "npm_path": "$$bin/npm$$"
  },
  "lsp_document_colors": "inlay",
  "minimap": {
    "current_line_highlight": "line",
    "display_in": "active_editor",
    "max_width_columns": 60,
    "show": "auto",
    "thumb": "always",
    "thumb_border": "left_open"
  },
  "on_last_window_closed": "quit_app",
  "outline_panel": {
    "dock": "left",
    "button": true
  },
  "prettier": {
    "allowed": true
  },
  "preview_tabs": {
    "enable_keep_preview_on_code_navigation": true,
    "enable_preview_from_file_finder": true,
    "enabled": true
  },
  "project_panel": {
    "dock": "left",
    "git_status": true,
    "indent_guides": {
      "show": "always"
    },
    "indent_size": 23,
    "scrollbar": {
      "show": "auto"
    }
  },
  "restore_on_startup": "last_session",
  "scrollbar": {
    "axes": {
      "horizontal": true
    },
    "cursors": true,
    "show": "auto"
  },
  "show_signature_help_after_edits": true,
  "snippet_sort_order": "inline",
  "soft_wrap": "none",
  "sticky_scroll": {
    "enabled": true
  },
  "tab_size": 2,
  "tabs": {
    "file_icons": true,
    "git_status": true,
    "show_diagnostics": "errors"
  },
  "telemetry": {
    "diagnostics": false,
    "metrics": false
  },
  "terminal": {
    "env": {
      "EDITOR": "zed-editor"
    },
    "shell": "system"
  },
  "ui_font_size": 15,
  "ui_font_weight": 500.0,
  "unnecessary_code_fade": 0.7,
  "vim_mode": false,
  "when_closing_with_no_tabs": "keep_window_open"
}
