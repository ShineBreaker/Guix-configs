import sys
import os

sys.path.insert(0, os.path.dirname(os.path.abspath(__file__)))

from kb_core import (  # noqa: E402
    KB_ROOT, KB_EXPERIENCES, KB_MEMORIES,
    KB_MEMORY, KB_PATTERNS, KB_INDEX, KB_INBOX, KB_PROFILE,
    VALID_TYPES, VALID_OWNERS, VALID_ENTRY_TYPES, VALID_STATUSES,
    STALE_DAYS,
    die, now, today,
    _load_index, _save_index, _rebuild_index,
    ensure_dirs, _init_profile,
)
from kb_cards import (  # noqa: E402
    cmd_add, cmd_get, cmd_list, cmd_search,
    cmd_fields, cmd_tags, cmd_inbox, cmd_stats,
    cmd_connect, cmd_update,
    cmd_touch, cmd_merge, cmd_archive, cmd_restore,
    cmd_deduplicate, cmd_review, cmd_health,
)
from kb_memory import cmd_memory, cmd_patterns  # noqa: E402
from kb_lint import cmd_lint  # noqa: E402

import argparse
import re
import shutil
import subprocess
from pathlib import Path

def cmd_init(args: argparse.Namespace) -> None:
    """初始化知识库目录结构，可选初始化 git 仓库。"""
    # 检查 KB_ROOT 是否已存在且有实质内容
    if KB_ROOT.exists() and any(KB_ROOT.iterdir()):
        has_cards = KB_EXPERIENCES.exists() and any(KB_EXPERIENCES.iterdir())
        if has_cards:
            print(f"知识库已存在且有内容: {KB_ROOT}")
            print("如需重新初始化，请先备份并删除该目录。")
            return
        # 有目录但无卡片——可能是损坏的初始化，继续
        print(f"知识库目录已存在但为空，继续初始化: {KB_ROOT}")

    # 创建目录和模板文件（复用 ensure_dirs 逻辑）
    ensure_dirs()
    print(f"目录结构已创建: {KB_ROOT}")

    # git 初始化（默认启用，--no-git 跳过）
    use_git = not args.no_git
    if use_git:
        git_bin = shutil.which("git")
        if not git_bin:
            print("提示: 未找到 git，跳过版本控制初始化。")
            print("安装 git 后可手动运行: cd ~/Documents/Org && git init && git add -A && git commit -m 'kb init'")
            return

        git_dir = KB_ROOT / ".git"
        if git_dir.exists():
            print("git 仓库已存在，跳过 git init。")
            return

        # 检查父目录是否已有 git 仓库（避免嵌套）
        parent_git = _find_parent_git(KB_ROOT)
        if parent_git:
            print(f"警告: 父目录已有 git 仓库 ({parent_git})")
            print("跳过 git init 以避免嵌套仓库。")
            print("如需独立版本控制，请手动运行: cd ~/Documents/Org && git init")
            return

        # 创建 .gitignore
        gitignore = KB_ROOT / ".gitignore"
        if not gitignore.exists():
            gitignore.write_text("# 机器生成索引\nindex.json\n", encoding="utf-8")

        # git init + 初始 commit
        _run_git(["init"], cwd=KB_ROOT)
        _run_git(["add", ".gitignore", "MEMORY.org", "profile.org", "inbox.org"], cwd=KB_ROOT)
        _run_git(["commit", "-m", "kb init: 初始化知识库"], cwd=KB_ROOT)
        print("git 仓库已初始化，初始 commit 已创建。")



def cmd_commit(args: argparse.Namespace) -> None:
    """提交知识库变更，封装 git add + commit。"""
    git_bin = shutil.which("git")
    if not git_bin:
        die("未找到 git，无法提交。")

    git_dir = KB_ROOT / ".git"
    if not git_dir.exists():
        die("知识库未初始化 git 仓库。请先运行 'kb init'。")

    message = args.message
    if not message:
        die("请通过 -m 指定 commit message。")

    # 检查是否有变更
    status = _run_git(["status", "--porcelain"], cwd=KB_ROOT)
    if not status.strip():
        print("没有待提交的变更。")
        return

    # add 所有变更（包括新建、修改、删除）
    _run_git(["add", "-A"], cwd=KB_ROOT)

    # commit
    _run_git(["commit", "-m", message], cwd=KB_ROOT)
    print(f"已提交: {message}")



def _run_git(args: list[str], cwd: Path) -> str:
    """执行 git 命令，返回 stdout。失败时 die。"""
    result = subprocess.run(
        ["git"] + args,
        capture_output=True,
        text=True,
        cwd=str(cwd),
    )
    if result.returncode != 0:
        die(f"git {' '.join(args)} 失败: {result.stderr.strip()}")
    return result.stdout


def _find_parent_git(start: Path) -> Path | None:
    """向上查找父目录中的 .git，返回其路径或 None。"""
    current = start.parent
    while current != current.parent:
        if (current / ".git").exists():
            return current / ".git"
        current = current.parent
    return None



def cmd_reindex(args: argparse.Namespace) -> None:
    """
    全量扫描 experiences/ 目录下所有卡片，重建 index.json。
    """
    ensure_dirs()

    index = _rebuild_index()
    _save_index(index)
    print(f"索引已重建: {index['total']} 条卡片 → {KB_INDEX}")


# ═══════════════════════════════════════════════════════════════════════════════

def cmd_profile(args: argparse.Namespace) -> None:
    """管理用户画像：查看、设置、追加分类条目。"""
    ensure_dirs()

    if not KB_PROFILE.exists():
        _init_profile(KB_PROFILE)

    action = getattr(args, "action", None)
    category = args.category

    if action is None:
        # 默认：显示
        if category:
            _profile_show_section(category)
        else:
            _profile_overview()
    elif action == "set":
        if not category:
            die("必须指定分类名来设置分类")
        content = sys.stdin.read().strip()
        if not content:
            die("必须通过 stdin 传入分类内容")
        _profile_set_section(category, content)
    elif action == "add":
        if not category:
            die("必须指定分类名来追加条目")
        content = args.text or ""
        if not content:
            content = sys.stdin.read().strip()
        if not content:
            die("必须指定 --text 或通过 stdin 传入追加内容")
        _profile_add_entry(category, content)


def _profile_overview() -> None:
    """显示画像概览：所有一级标题和条目数。"""
    content = KB_PROFILE.read_text(encoding="utf-8")
    sections = re.findall(r"^\* (.+)", content, re.MULTILINE)
    if not sections:
        print("(用户画像为空)")
        return

    print("═══ 用户画像 ═══")
    for section in sections:
        # 计算该标题下的条目数（到下一个同级标题为止）
        pattern = rf"^\* {re.escape(section)}\n((?:.*\n)*?)(?=^\* |\Z)"
        m = re.search(pattern, content, re.MULTILINE)
        if m:
            body = m.group(1)
            items = len([l for l in body.split("\n") if l.strip().startswith("- ")])
            sub = len(re.findall(r"^\*\* ", body, re.MULTILINE))
            parts = []
            if items:
                parts.append(f"{items} 条目")
            if sub:
                parts.append(f"{sub} 子类")
            detail = f" ({', '.join(parts)})" if parts else ""
            print(f"  {section}{detail}")
        else:
            print(f"  {section}")


def _profile_show_section(category: str) -> None:
    """显示指定分类的内容。"""
    content = KB_PROFILE.read_text(encoding="utf-8")

    # 支持一级或二级标题匹配
    for level in (r"\*", r"\*\*"):
        if level == r"\*":
            next_level = r"^\* [^\n*]"
        else:
            next_level = r"^\*\* [^\n*]"
        pattern = rf"^{level} {re.escape(category)}\n"
        m = re.search(pattern, content, re.MULTILINE)
        if m:
            start = m.end()
            rest = content[start:]
            next_m = re.search(next_level, rest, re.MULTILINE)
            if next_m:
                body = rest[: next_m.start()]
            else:
                body = rest
            display_level = "*" if level == r"\*" else "**"
            print(f"{display_level} {category}")
            print(body.rstrip())
            return

    avail = ", ".join(re.findall(r"^\* (.+)", content, re.MULTILINE))
    die(f"未找到分类: {category}（可用分类: {avail}）")


def _profile_set_section(category: str, new_body: str) -> None:
    """设置指定分类的内容（覆盖该分类下的全部条目）。"""
    content = KB_PROFILE.read_text(encoding="utf-8")

    pattern = rf"^\* {re.escape(category)}\n"
    m = re.search(pattern, content, re.MULTILINE)
    if not m:
        # 追加新分类到文件末尾
        content = content.rstrip("\n") + f"\n\n* {category}\n{new_body}\n"
    else:
        start = m.end()
        rest = content[start:]
        next_m = re.search(r"^\* ", rest, re.MULTILINE)
        if next_m:
            end = start + next_m.start()
        else:
            end = len(content)
        content = content[: m.start()] + f"* {category}\n{new_body}\n" + content[end:]

    KB_PROFILE.write_text(content, encoding="utf-8")
    print(f"已更新分类 [{category}] → {KB_PROFILE}")


def _profile_add_entry(category: str, entry: str) -> None:
    """追加条目到指定分类。"""
    content = KB_PROFILE.read_text(encoding="utf-8")

    # 确保条目以 "- " 开头
    if not entry.startswith("- "):
        entry = f"- {entry}"

    pattern = rf"^\* {re.escape(category)}\n"
    m = re.search(pattern, content, re.MULTILINE)
    if m:
        start = m.end()
        rest = content[start:]
        next_m = re.search(r"^\* ", rest, re.MULTILINE)
        if next_m:
            end = start + next_m.start()
        else:
            end = len(content)
        # 在该分类内容末尾追加
        section_content = content[start:end].rstrip("\n")
        content = content[:start] + section_content + f"\n{entry}\n" + content[end:]
    else:
        content = content.rstrip("\n") + f"\n\n* {category}\n{entry}\n"

    KB_PROFILE.write_text(content, encoding="utf-8")
    print(f"已追加到 [{category}] → {KB_PROFILE}")


# ═══════════════════════════════════════════════════════════════════════════════
