{
  "name": "opencode",
  "version": "1.0",
  "description": "OpenCode AI Agent",
  "bin": "opencode",
  "bin_check": ["opencode", "version"],
  "bin_min_version": "1.15.13",

  "run": {
    "args_template": ["run", "--format", "json"],
    "input_method": "arg",
    "input_flag": null,
    "output_format": "jsonl",
    "working_dir": "project_root",
    "timeout_sec": 600
  },

  "extract": {
    "type": "jsonl-last-assistant-text"
  },

  "session": {
    "supported": true,
    "fresh_per_step": true,
    "session_dir_flag": null,
    "resume_flag": "--continue"
  },

  "completion": {
    "marker": "<promise>LOOP_COMPLETE</promise>",
    "marker_scan_tail_chars": 4000,
    "native_command": null
  },

  "env": {},

  "extra_args": [],

  "examples": {
    "smoke_test_prompt": "Reply with exactly: OK"
  }
}
