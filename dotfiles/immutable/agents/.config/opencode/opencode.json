{
  "$schema": "https://opencode.ai/config.json",
  "instructions": [
    "~/.config/agents/context/01-language.md",
    "~/.config/agents/context/02-ultilities.md"
  ],
  "mcp": {
    "playwright": {
      "command": [
        "npx",
        "@playwright/mcp@latest"
      ],
      "enabled": true,
      "type": "local"
    }
  },
  "plugin": [
    "@tarquinen/opencode-dcp",
    "@franlol/opencode-md-table-formatter",
    "opencode-mem",
    "opencode-scheduler",
    "oh-my-openagent"
  ]
}