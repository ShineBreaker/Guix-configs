#!/usr/bin/env bash

# SPDX-FileCopyrightText: 2026 BrokenShine <xchai404@gmail.com>
#
# SPDX-License-Identifier: MIT
set -euo pipefail

# sidebar-toggle — tmux 侧边栏 pane 生命周期与事件适配器
#
# Bash 只处理 tmux pane 生命周期。渲染、点击和折叠状态由长驻 Guile
# 进程负责；两者通过每个 sidebar pane 独有的 FIFO 通信。

scripts_dir="${HOME}/.config/tmux/scripts"
sidebar_title="tmux-sidebar"
sidebar_command="sidebar-render.scm daemon"

is_sidebar() {
    local title="$1" start="$2"
    [[ "$title" == "$sidebar_title" || "$start" == *"$sidebar_command"* ]]
}

fifo_path() {
    local pane_id="${1#%}"
    printf '/tmp/tmux-sidebar-%s-%s.fifo' "$UID" "$pane_id"
}

send_event() {
    local pane_id="$1" event="$2" fifo fd
    fifo="$(fifo_path "$pane_id")"
    [[ -p "$fifo" ]] || return 0

    # O_RDWR 打开 FIFO，即使 daemon 正在退出也不会阻塞 hook。
    exec {fd}<>"$fifo" || return 0
    printf '%s\n' "$event" >&"$fd" || true
    exec {fd}>&-
}

kill_sidebar_pane() {
    local pane_id="$1" pane_pid
    pane_pid="$(tmux display-message -p -t "$pane_id" '#{pane_pid}' 2>/dev/null || true)"
    if [[ "$pane_pid" =~ ^[0-9]+$ ]]; then
        # tmux may remove the pane without reaping an exec'd daemon.
        kill -TERM "$pane_pid" 2>/dev/null || true
    fi
    rm -f -- "$(fifo_path "$pane_id")"
    tmux kill-pane -t "$pane_id" 2>/dev/null || true
}

current_sidebar() {
    local pane_id title start
    while IFS=$'\t' read -r pane_id title start; do
        if is_sidebar "$title" "$start"; then
            printf '%s\n' "$pane_id"
            return 0
        fi
    done < <(tmux list-panes -F $'#{pane_id}\t#{pane_title}\t#{pane_start_command}' 2>/dev/null || true)
    return 1
}

signal_current() {
    local pane_id
    pane_id="$(current_sidebar || true)"
    # 末尾 || true：没有侧栏 pane 是正常的 no-op（例如 follow 尚未建好侧栏时的
    # 竞态），不应让脚本在 set -e 下以非零退出，否则 tmux run-shell 会在状态栏
    # 显示 "'...sidebar-toggle signal' returned 1"。
    [[ -n "$pane_id" ]] && send_event "$pane_id" "refresh" || true
}

kill_all_sidebars() {
    local pane_id title start
    while IFS=$'\t' read -r pane_id title start; do
        if is_sidebar "$title" "$start"; then
            kill_sidebar_pane "$pane_id"
        fi
    done < <(tmux list-panes -a -F $'#{pane_id}\t#{pane_title}\t#{pane_start_command}' 2>/dev/null || true)
}

ensure_sidebar() {
    local context window_id no_sidebar configured_width width socket_key lock_file
    context="$(tmux display-message -p $'#{window_id}\t#{@no_sidebar}\t#{@sidebar_width}' 2>/dev/null)" || return 0
    IFS=$'\t' read -r window_id no_sidebar configured_width <<<"$context"
    [[ -n "$window_id" ]] || return 0

    socket_key="${TMUX%%,*}"
    socket_key="${socket_key##*/}-${window_id#@}"
    lock_file="/tmp/tmux-sidebar-${UID}-${socket_key}.lock"
    exec 9>"$lock_file"
    flock -n 9 || return 0

    local pane_id active title start
    local sidebar_id="" target_id="" fallback_id=""
    local -a duplicate_ids=()

    while IFS=$'\t' read -r pane_id active title start; do
        if is_sidebar "$title" "$start"; then
            if [[ -z "$sidebar_id" ]]; then
                sidebar_id="$pane_id"
            else
                duplicate_ids+=("$pane_id")
            fi
            continue
        fi

        [[ -n "$fallback_id" ]] || fallback_id="$pane_id"
        [[ "$active" == "1" ]] && target_id="$pane_id"
    done < <(tmux list-panes -t "$window_id" -F $'#{pane_id}\t#{pane_active}\t#{pane_title}\t#{pane_start_command}' 2>/dev/null || true)

    for pane_id in "${duplicate_ids[@]}"; do
        kill_sidebar_pane "$pane_id"
    done

    if [[ "$no_sidebar" == "1" ]]; then
        [[ -n "$sidebar_id" ]] && kill_sidebar_pane "$sidebar_id"
        return 0
    fi

    if [[ -n "$sidebar_id" ]]; then
        send_event "$sidebar_id" "refresh"
        return 0
    fi

    target_id="${target_id:-$fallback_id}"
    if [[ -z "$target_id" ]]; then
        tmux display-message "侧边栏创建失败：当前窗口没有普通窗格"
        return 1
    fi

    width="${SIDEBAR_WIDTH:-$configured_width}"
    [[ "$width" =~ ^[0-9]+$ ]] || width=32

    local new_id
    new_id="$(tmux split-window -d -t "$target_id" -h -b -f -l "$width" -P -F '#{pane_id}' \
        "exec guile --no-auto-compile -q -s ${scripts_dir}/sidebar-render.scm daemon" 2>/dev/null)" || {
        tmux display-message "侧边栏创建失败（需要 tmux 3.3a+）"
        tmux set-option -g @sidebar_visible 0
        return 1
    }
    tmux select-pane -t "$new_id" -T "$sidebar_title" 2>/dev/null || true
}

case "${1:-toggle}" in
    toggle)
        if [[ "$(tmux show-option -gqv @sidebar_visible 2>/dev/null || echo 0)" == "1" ]]; then
            kill_all_sidebars
            tmux set-option -g @sidebar_visible 0
        else
            tmux set-option -g @sidebar_visible 1
            ensure_sidebar
        fi
        ;;
    follow)
        if [[ "$(tmux show-option -gqv @sidebar_visible 2>/dev/null || echo 0)" == "1" ]]; then
            ensure_sidebar
        fi
        ;;
    signal)
        signal_current
        ;;
    click)
        [[ $# -ge 5 ]] || exit 2
        send_event "$4" $'click\t'"$2"$'\t'"$3"$'\t'"$5"
        ;;
    toggle-group)
        pane_id="$(current_sidebar || true)"
        [[ -n "$pane_id" ]] && send_event "$pane_id" "toggle-group" || true
        ;;
    *)
        printf 'usage: sidebar-toggle [toggle|follow|signal|click|toggle-group]\n' >&2
        exit 2
        ;;
esac
