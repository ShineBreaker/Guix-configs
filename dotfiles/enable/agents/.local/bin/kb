# kb — 知识库查询工具（只读）
# 供 AI Agent 和人类在终端检索经验卡片和记忆索引。
#
# 用法: kb <子命令> [参数]
# 详细子命令列表请运行 kb help。

import sys
import os
import argparse

sys.path.insert(0, os.path.dirname(os.path.abspath(__file__)))

from kb_lib.core import (  # noqa: E402
    KB_ROOT,
    KB_EXPERIENCES,
    KB_MEMORY,
    KB_INDEX,
    STALE_DAYS,
    die,
    now,
    ensure_dirs,
)
from kb_lib.cards import (  # noqa: E402
    cmd_get,
    cmd_list,
    cmd_search,
    cmd_fields,
    cmd_tags,
    cmd_stats,
    cmd_health,
)
from kb_lib.memory import cmd_memory  # noqa: E402
from kb_lib.lint import cmd_lint  # noqa: E402
from kb_lib.viz.cli import add_viz_parser, cmd_viz  # noqa: E402


# ═══════════════════════════════════════════════════════════════════════════════
# 子命令: reindex
# ═══════════════════════════════════════════════════════════════════════════════

def cmd_reindex(args: argparse.Namespace) -> None:
    """全量扫描 experiences/ 目录下所有卡片，重建 index.json。"""
    ensure_dirs()
    from kb_lib.core import _rebuild_index, _save_index
    index = _rebuild_index()
    _save_index(index)
    print(f"索引已重建: {index['total']} 条卡片 → {KB_INDEX}")


# ═══════════════════════════════════════════════════════════════════════════════
# 帮助文本
# ═══════════════════════════════════════════════════════════════════════════════

def print_help() -> None:
    print(f"""kb — 知识库查询工具（只读）

用法: kb <子命令> [参数]

读取:
  get       读取卡片详情
            kb get <卡片文件名或ID>

  list      列出卡片
            kb list --category 类别 --all
            kb list [--category 类别] [--type 类型] [--owner 执行者] [--recent N] [--all]

  search    全文检索
            kb search <关键词...> [--context N] [--limit N]
            kb search --regex <正则> [--context N]
            默认按空格、/、逗号拆分多关键词，大小写不敏感，按命中词数和次数排序。
            需要旧式 rg/grep 正则行为时显式加 --regex。

  fields    列出已有字段值
            kb fields [--category] [--tech] [--type] [--owner]

  tags      按标签检索
            kb tags <标签> [标签2 ...]

  memory    查阅记忆系统
            kb memory                          列出记忆概览
            kb memory --type feedback|project|reference  按类型过滤
            kb memory --project <名称|路径|.>   检索项目记忆
            kb memory --stale                   列出陈旧记忆
            kb memory --get                     查看全文
            kb memory --get --type feedback     查看指定节全文

诊断:
  stats     知识库统计概览
            kb stats

  health    知识库健康度报告
            kb health

  viz       可视化总结（D3.js 力导向图）
            kb viz                          交互式 HTML 可视化
            kb viz --text                   纯文本摘要
            kb viz --output report.html     输出到文件

维护:
  reindex   重建知识库索引
            kb reindex

  lint      格式校验与修复
            kb lint                 检查所有卡片
            kb lint --fix           自动修复
            kb lint --check         仅检查

  help      显示本帮助

配置常量:
  KB_ROOT      知识库根目录 ({KB_ROOT})
  STALE_DAYS   陈旧记忆阈值 ({STALE_DAYS} 天)

知识库路径: {KB_ROOT}
经验卡片目录: {KB_EXPERIENCES}
记忆文件: {KB_MEMORY}
""")


# ═══════════════════════════════════════════════════════════════════════════════
# 主入口
# ═══════════════════════════════════════════════════════════════════════════════

def main() -> None:
    if len(sys.argv) > 1 and sys.argv[1] in ("-h", "--help"):
        print_help()
        sys.exit(0)

    ensure_dirs()

    parser = argparse.ArgumentParser(
        prog="kb",
        description="kb — 知识库查询工具（只读）",
        add_help=False,
    )
    subparsers = parser.add_subparsers(dest="command")

    # ── get ───────────────────────────────────────────────────────────────
    get_parser = subparsers.add_parser("get", help="读取卡片详情")
    get_parser.add_argument("target", help="卡片文件名或ID")

    # ── list ──────────────────────────────────────────────────────────────
    list_parser = subparsers.add_parser("list", help="列出卡片")
    list_parser.add_argument("--category", help="按类别过滤")
    list_parser.add_argument("--cagetory", dest="category", help=argparse.SUPPRESS)
    list_parser.add_argument("--type", help="按类型过滤")
    list_parser.add_argument("--owner", help="按执行者过滤")
    list_parser.add_argument("--recent", type=int, help="显示最近 N 条")
    list_parser.add_argument("--all", action="store_true", help="显示全部")

    # ── search ────────────────────────────────────────────────────────────
    search_parser = subparsers.add_parser("search", help="全文检索")
    search_parser.add_argument("query", help="关键词；默认按多关键词相关度检索")
    search_parser.add_argument("--context", type=int, default=3, help="上下文行数")
    search_parser.add_argument("--limit", type=int, default=20, help="最多显示的文件数")
    search_parser.add_argument("--max-blocks", type=int, default=4, help="每个文件最多显示的上下文块数")
    search_parser.add_argument("--all-terms", action="store_true", help="只显示包含所有关键词的文件")
    search_parser.add_argument("--case-sensitive", action="store_true", help="大小写敏感匹配")
    search_parser.add_argument("--regex", action="store_true", help="使用旧版 rg/grep 正则检索模式")
    search_parser.add_argument("--json", action="store_true", help="JSON 输出")

    # ── fields ────────────────────────────────────────────────────────────
    fields_parser = subparsers.add_parser("fields", help="列出已有字段值")
    fields_parser.add_argument("--category", action="store_true", help="只列出 category")
    fields_parser.add_argument("--tech", action="store_true", help="只列出 tech")
    fields_parser.add_argument("--type", dest="type_", action="store_true", help="只列出 type")
    fields_parser.add_argument("--owner", action="store_true", help="只列出 owner")
    fields_parser.add_argument("--json", action="store_true", help="JSON 输出")

    # ── tags ──────────────────────────────────────────────────────────────
    tags_parser = subparsers.add_parser("tags", help="按标签检索")
    tags_parser.add_argument("tags", nargs="+", help="标签")
    tags_parser.add_argument("--json", action="store_true", help="JSON 输出")

    # ── memory ──────────────────────────────────────────────────────────
    memory_parser = subparsers.add_parser("memory", help="查阅记忆系统")
    memory_parser.add_argument("--type", choices=["feedback", "project", "reference"], help="记忆类型过滤")
    memory_parser.add_argument("--project", metavar="IDENTIFIER", help="项目名或路径")
    memory_parser.add_argument("--get", action="store_true", help="查看记忆全文")
    memory_parser.add_argument("--stale", action="store_true", help="列出陈旧记忆")

    # ── reindex ───────────────────────────────────────────────────────────
    subparsers.add_parser("reindex", help="重建知识库索引")

    # ── lint ──────────────────────────────────────────────────────────────
    lint_parser = subparsers.add_parser("lint", help="格式校验与修复")
    lint_parser.add_argument("--fix", action="store_true", help="自动修复")
    lint_parser.add_argument("--check", action="store_true", help="仅检查，退出码=min(问题数,127)")
    lint_parser.add_argument("files", nargs="*", help="目标文件（默认检查全部）")

    # ── stats ───────────────────────────────────────────────────────────────
    subparsers.add_parser("stats", help="知识库统计概览")

    # ── health ──────────────────────────────────────────────────────────────
    subparsers.add_parser("health", help="知识库健康度报告")

    # ── help ──────────────────────────────────────────────────────────────
    subparsers.add_parser("help", help="显示本帮助")

    # ── viz ──────────────────────────────────────────────────────────────
    add_viz_parser(subparsers)

    args = parser.parse_args()

    if args.command is None or args.command == "help":
        print_help()
        sys.exit(0)

    commands = {
        "get": cmd_get,
        "list": cmd_list,
        "search": cmd_search,
        "fields": cmd_fields,
        "tags": cmd_tags,
        "memory": cmd_memory,
        "reindex": cmd_reindex,
        "lint": cmd_lint,
        "stats": cmd_stats,
        "health": cmd_health,
        "viz": cmd_viz,
    }

    if args.command in commands:
        commands[args.command](args)
    else:
        die(f"未知子命令: {args.command}。运行 'kb help' 查看帮助。")


if __name__ == "__main__":
    main()
