{
  "$schema": "https://opencode.ai/config.json",
  "agent": {
    "explore": {
      "disable": true
    },
    "general": {
      "disable": true
    }
  },
  "instructions": [
    "~/.config/agents/context/01-language.md",
    "~/.config/agents/context/02-ultilities.md"
  ],
  "lsp": true,
  "mcp": {
    "playwright": {
      "command": [
        "npx",
        "@playwright/mcp@latest"
      ],
      "enabled": true,
      "type": "local"
    },
    "agenote": {
      "command": [
        "/home/brokenshine/.guix-home/profile/bin/python3",
        "/home/brokenshine/.local/bin/agenote_mcp.py"
      ],
      "env": {"AGENOTE_AGENT": "opencode"},
      "enabled": true,
      "type": "local"
    }
  },
  "permission": "allow",
  "plugin": [
    "@tarquinen/opencode-dcp",
    "@franlol/opencode-md-table-formatter",
    "opencode-mem",
    "opencode-scheduler",
    "@plannotator/opencode"
  ]
}