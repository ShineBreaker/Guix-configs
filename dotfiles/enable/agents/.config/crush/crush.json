{
  "$schema": "https://charm.land/crush.json",
  "tools": {
    "ls": {
      "max_depth": 6,
      "max_items": 400
    },
    "grep": {
      "timeout": 15
    }
  },
  "options": {
    "context_paths": [
      "~/.agents/context/01-language.md",
      "~/.agents/context/02-ultilities.md"
    ],
    "tui": {
      "compact_mode": true,
      "diff_mode": "split",
      "transparent": true,
      "completions": {
        "max_depth": 3,
        "max_items": 200
      }
    },
    "initialize_as": "AGENTS.md",
    "auto_lsp": true,
    "progress": true,
    "disable_provider_auto_update": false
  },
  "permissions": {
    "allowed_tools": [
      "agent",
      "agentic_fetch",
      "download",
      "edit",
      "fetch",
      "glob",
      "grep",
      "job_kill",
      "job_output",
      "ls",
      "lsp_diagnostics",
      "lsp_references",
      "mcp_context7_query-docs",
      "mcp_context7_resolve-library-id",
      "mcp_filesystem_create_directory",
      "mcp_filesystem_edit_file",
      "mcp_filesystem_get_file_info",
      "mcp_filesystem_list_allowed_directories",
      "mcp_filesystem_list_directory",
      "mcp_filesystem_move_file",
      "mcp_filesystem_read_file",
      "mcp_filesystem_read_media_file",
      "mcp_filesystem_read_multiple_files",
      "mcp_filesystem_read_text_file",
      "mcp_filesystem_search_files",
      "mcp_filesystem_write_file",
      "mcp_filesystem_write_multiple_files",
      "mcp_sequential_thinking_sequentialthinking",
      "multiedit",
      "sourcegraph",
      "mcp_agenote_agenote_init",
      "mcp_agenote_agenote_add",
      "mcp_agenote_agenote_get",
      "mcp_agenote_agenote_search",
      "mcp_agenote_agenote_list",
      "mcp_agenote_agenote_stats",
      "mcp_agenote_agenote_health",
      "mcp_agenote_agenote_touch",
      "mcp_agenote_agenote_curate",
      "mcp_agenote_agenote_deduplicate",
      "mcp_agenote_agenote_archive",
      "mcp_agenote_agenote_restore",
      "mcp_agenote_agenote_reindex",
      "mcp_agenote_agenote_memory_overview",
      "mcp_agenote_agenote_memory_get",
      "mcp_agenote_agenote_memory_add",
      "mcp_agenote_agenote_memory_search",
      "todos",
      "view",
      "write"
    ]
  },
  "hooks": {
    "PreToolUse": [{
      "matcher": "^(view|ls|grep|glob|lsp_diagnostics|lsp_references|sourcegraph|fetch|download|agentic_fetch|job_output|todos|list_mcp_resources|read_mcp_resource|mcp_context7_query-docs|mcp_context7_resolve-library-id|mcp_filesystem_list_allowed_directories|mcp_filesystem_list_directory|mcp_filesystem_read_file|mcp_filesystem_read_text_file|mcp_filesystem_read_media_file|mcp_filesystem_read_multiple_files|mcp_filesystem_search_files|mcp_filesystem_get_file_info|mcp_sequential_thinking_sequentialthinking)$",
      "command": "echo '{\"decision\":\"allow\"}'"
    }, {
      "matcher": "^bash$",
      "command": "~/.config/crush/hooks/bash-gate.sh"
    }, {
      "matcher": "^(edit|write|multiedit)$",
      "command": "~/.config/crush/hooks/edit-gate.sh"
    }]
  },
  "providers": {
    "zhipu": {
      "api_key": "$ZAI_API_KEY",
      "base_url": "https://open.bigmodel.cn/api/coding/paas/v4",
      "disable": false,
      "id": "Zhipu",
      "models": [{
        "id": "glm-5.2",
        "name": "GLM-5.2",
        "context_window": 1000000,
        "default_max_tokens": 65536
      }],
      "name": "Zhipu Provider",
      "type": "openai"
    }
  },
  "models": {
    "large": {
      "provider": "zhipu",
      "model": "glm-5.1",
      "think": true,
      "max_tokens": 65536
    },
    "small": {
      "provider": "deepseek",
      "model": "deepseek-v4-flash",
      "think": true,
      "max_tokens": 65536
    },
    "quick": {
      "provider": "deepseek",
      "model": "deepseek-v4-flash",
      "max_tokens": 32768
    }
  },
  "lsp": {
    "c_cpp": {
      "command": "~/.guix-home/profile/bin/ccls",
      "filetypes": [
        "c",
        "cc",
        "cpp",
        "cxx",
        "h",
        "hpp"
      ],
      "root_markers": [
        ".ccls",
        "compile_commands.json",
        "compile_flags.txt",
        "CMakeLists.txt",
        "meson.build",
        "Makefile"
      ],
      "timeout": 30
    },
    "python": {
      "command": "~/.guix-home/profile/bin/pylsp",
      "filetypes": [
        "py"
      ],
      "root_markers": [
        "pyproject.toml",
        "setup.py",
        "setup.cfg",
        "requirements.txt",
        "uv.lock",
        ".venv"
      ],
      "options": {
        "pylsp": {
          "plugins": {
            "black": {
              "enabled": true
            },
            "pylsp_mypy": {
              "enabled": true,
              "live_mode": false
            },
            "rope": {
              "enabled": true
            },
            "pycodestyle": {
              "enabled": false
            },
            "mccabe": {
              "enabled": false
            },
            "pyflakes": {
              "enabled": false
            }
          }
        }
      },
      "timeout": 30
    },
    "rust": {
      "command": "~/.guix-home/profile/bin/rust-analyzer",
      "filetypes": [
        "rs"
      ],
      "root_markers": [
        "Cargo.toml",
        "rust-project.json"
      ],
      "timeout": 30
    },
    "java": {
      "command": "~/.guix-home/profile/bin/jdtls",
      "filetypes": [
        "java"
      ],
      "root_markers": [
        "pom.xml",
        "build.gradle",
        "build.gradle.kts",
        "settings.gradle",
        "settings.gradle.kts"
      ],
      "timeout": 60
    },
    "typescript": {
      "command": "~/.config/crush/bin/typescript-language-server",
      "args": [
        "--stdio"
      ],
      "filetypes": [
        "js",
        "jsx",
        "ts",
        "tsx"
      ],
      "root_markers": [
        "package.json",
        "tsconfig.json",
        "jsconfig.json",
        "deno.json",
        "deno.jsonc",
        "bun.lock",
        "pnpm-lock.yaml",
        "yarn.lock"
      ],
      "timeout": 60
    },
    "html": {
      "command": "~/.config/crush/bin/vscode-html-language-server",
      "args": [
        "--stdio"
      ],
      "filetypes": [
        "html",
        "htm"
      ],
      "root_markers": [
        "package.json",
        ".git"
      ],
      "timeout": 60
    },
    "css": {
      "command": "~/.config/crush/bin/vscode-css-language-server",
      "args": [
        "--stdio"
      ],
      "filetypes": [
        "css",
        "scss",
        "less"
      ],
      "root_markers": [
        "package.json",
        ".git"
      ],
      "timeout": 60
    },
    "json": {
      "command": "~/.config/crush/bin/vscode-json-language-server",
      "args": [
        "--stdio"
      ],
      "filetypes": [
        "json",
        "jsonc"
      ],
      "root_markers": [
        "package.json",
        ".git"
      ],
      "timeout": 60
    },
    "markdown": {
      "command": "~/.config/crush/bin/vscode-markdown-language-server",
      "args": [
        "--stdio"
      ],
      "filetypes": [
        "md",
        "markdown"
      ],
      "root_markers": [
        ".git"
      ],
      "timeout": 60
    },
    "eslint": {
      "command": "~/.config/crush/bin/vscode-eslint-language-server",
      "args": [
        "--stdio"
      ],
      "filetypes": [
        "js",
        "jsx",
        "ts",
        "tsx"
      ],
      "root_markers": [
        "package.json",
        ".eslintrc",
        ".eslintrc.json",
        ".eslintrc.js",
        "eslint.config.js",
        "eslint.config.mjs",
        "eslint.config.cjs",
        "eslint.config.ts"
      ],
      "timeout": 60
    },
    "bash": {
      "command": "~/.config/crush/bin/bash-language-server",
      "args": [
        "start"
      ],
      "filetypes": [
        "sh",
        "bash",
        "zsh"
      ],
      "root_markers": [
        ".git"
      ],
      "timeout": 60
    },
    "nix": {
      "disabled": true,
      "command": "nil",
      "filetypes": [
        "nix"
      ],
      "root_markers": [
        "flake.nix",
        "shell.nix",
        "default.nix"
      ],
      "timeout": 30
    },
    "zig": {
      "disabled": true,
      "command": "zls",
      "filetypes": [
        "zig"
      ],
      "root_markers": [
        "build.zig",
        "build.zig.zon"
      ],
      "timeout": 30
    },
    "scheme": {
      "command": "~/.guix-home/profile/bin/guile-lsp-server",
      "filetypes": ["scm", "ss"],
      "root_markers": [".git", "guix.scm", "manifest.scm"],
      "timeout": 30
    },
    "kotlin": {
      "disabled": true,
      "command": "kotlin-language-server",
      "filetypes": [
        "kt",
        "kts"
      ],
      "root_markers": [
        "build.gradle",
        "build.gradle.kts",
        "settings.gradle",
        "settings.gradle.kts"
      ],
      "timeout": 60
    }
  },
  "mcp": {
    "context7": {
      "type": "stdio",
      "command": "~/.config/crush/bin/context7-mcp",
      "timeout": 45
    },
    "agenote": {
      "type": "stdio",
      "command": "/home/brokenshine/.guix-home/profile/bin/python3",
      "args": ["/home/brokenshine/.local/bin/agenote_mcp.py"],
      "timeout": 45
    }
  }
}