#!/usr/bin/env bash
# SPDX-FileCopyrightText: 2026 BrokenShine <xchai404@gmail.com>
# SPDX-License-Identifier: MIT
#
# keepassxc-credential-setup — 管理 git-credential-keepassxc 配置文件
#
# 用法：
#   keepassxc-credential-setup status     检查配置健康状态
#   keepassxc-credential-setup init       初始化完整配置（databases + callers）
#   keepassxc-credential-setup update     更新过期的 callers 路径
#   keepassxc-credential-setup callers    仅重新注册 callers（不影响 databases）

set -euo pipefail

CONFIG_FILE="${XDG_CONFIG_HOME:-$HOME/.config}/git-credential-keepassxc"
COMMAND="${1:-help}"

# --- 辅助函数 ---

msg()  { printf ":: %s\n" "$*"; }
warn() { printf "WARNING: %s\n" "$*" >&2; }
die()  { printf "ERROR: %s\n" "$*" >&2; exit 1; }

need_cmd() {
    command -v "$1" &>/dev/null || die "需要 $1 但未找到"
}

# 输出当前系统预期的 caller 路径（每行一个）
_expected_caller_paths() {
    if command -v fish &>/dev/null; then
        readlink -f "$(command -v fish)"
    fi
    if command -v git &>/dev/null; then
        local git_real git_root git_libexec
        git_real="$(readlink -f "$(command -v git)")"
        git_root="$(dirname "$(dirname "$git_real")")"
        git_libexec="${git_root}/libexec/git-core/git"
        if [[ -e "$git_libexec" ]]; then
            echo "$git_libexec"
        else
            echo "$git_real"
        fi
    fi
}

# --- 子命令 ---

cmd_status() {
    need_cmd jq

    if [[ ! -f "$CONFIG_FILE" ]]; then
        msg "配置文件不存在: $CONFIG_FILE"
        msg "运行 'keepassxc-credential-setup init' 初始化"
        return 0
    fi

    local has_issue=0

    # 检查 databases
    local db_count
    db_count=$(jq '.databases | length' "$CONFIG_FILE")
    if [[ "$db_count" -eq 0 ]]; then
        warn "databases 为空 — 需要运行 'configure' 关联 KeePassXC"
        has_issue=1
    else
        msg "databases: ${db_count} 个已关联"
    fi

    # 检查 callers
    local caller_count
    caller_count=$(jq '.callers | length' "$CONFIG_FILE")
    if [[ "$caller_count" -eq 0 ]]; then
        warn "callers 为空"
        has_issue=1
    else
        msg "callers: ${caller_count} 个已注册"

        # 检查 1: 配置中的路径是否存在
        local i=0
        while [[ $i -lt "$caller_count" ]]; do
            local path
            path=$(jq -r ".callers[$i].path" "$CONFIG_FILE")
            if [[ ! -e "$path" ]]; then
                warn "  [$i] 路径不存在: $path"
                has_issue=1
            else
                msg "  [$i] 存在: $path"
            fi
            ((i++)) || true
        done

        # 检查 2: 当前系统实际路径是否已在配置中（检测包升级后 store hash 变化）
        local expected_paths
        expected_paths="$(_expected_caller_paths)"
        while IFS= read -r expected; do
            [[ -z "$expected" ]] && continue
            local found=0 j=0
            while [[ $j -lt "$caller_count" ]]; do
                local path
                path=$(jq -r ".callers[$j].path" "$CONFIG_FILE")
                if [[ "$path" == "$expected" ]]; then
                    found=1
                    break
                fi
                ((j++)) || true
            done
            if [[ "$found" -eq 0 ]]; then
                warn "  当前系统路径未注册: $expected"
                has_issue=1
            fi
        done <<< "$expected_paths"
    fi

    if [[ "$has_issue" -eq 0 ]]; then
        msg "配置健康 ✓"
    else
        msg "发现问题 — 运行 'keepassxc-credential-setup update' 修复"
    fi

    return "$has_issue"
}

cmd_init() {
    need_cmd git-credential-keepassxc

    if [[ -f "$CONFIG_FILE" ]]; then
        die "配置文件已存在: $CONFIG_FILE。如需重建请先备份后删除。"
    fi

    msg "步骤 1/2: 关联 KeePassXC 数据库..."
    git-credential-keepassxc configure --group "Git"

    msg "步骤 2/2: 注册 callers..."
    _write_callers

    msg "初始化完成 ✓"
    cmd_status
}

cmd_update() {
    need_cmd jq
    need_cmd git-credential-keepassxc

    if [[ ! -f "$CONFIG_FILE" ]]; then
        die "配置文件不存在，请先运行 'keepassxc-credential-setup init'"
    fi

    # 检查是否有 databases
    local db_count
    db_count=$(jq '.databases | length' "$CONFIG_FILE")
    if [[ "$db_count" -eq 0 ]]; then
        msg "databases 为空，需要先关联 KeePassXC..."
        git-credential-keepassxc configure --group "Git"
    fi

    # 检查 callers 是否需要更新
    local needs_update=0
    local caller_count
    caller_count=$(jq '.callers | length' "$CONFIG_FILE")

    # 检查 1: 路径是否不存在
    local i=0
    while [[ $i -lt "$caller_count" ]]; do
        local path
        path=$(jq -r ".callers[$i].path" "$CONFIG_FILE")
        if [[ ! -e "$path" ]]; then
            msg "路径不存在: $path"
            needs_update=1
        fi
        ((i++)) || true
    done

    # 检查 2: 当前系统路径是否已在配置中
    local expected_paths
    expected_paths="$(_expected_caller_paths)"
    while IFS= read -r expected; do
        [[ -z "$expected" ]] && continue
        local found=0 j=0
        while [[ $j -lt "$caller_count" ]]; do
            local path
            path=$(jq -r ".callers[$j].path" "$CONFIG_FILE")
            if [[ "$path" == "$expected" ]]; then
                found=1
                break
            fi
            ((j++)) || true
        done
        if [[ "$found" -eq 0 ]]; then
            msg "当前系统路径未在配置中: $expected"
            needs_update=1
        fi
    done <<< "$expected_paths"

    if [[ "$needs_update" -eq 0 ]]; then
        msg "所有 callers 路径均有效且为当前版本，无需更新"
        return 0
    fi

    msg "更新 callers..."
    _write_callers

    msg "更新完成 ✓"
    cmd_status
}

cmd_callers() {
    if [[ ! -f "$CONFIG_FILE" ]]; then
        die "配置文件不存在，请先运行 'keepassxc-credential-setup init'"
    fi

    msg "重新注册 callers..."
    _write_callers

    msg "完成 ✓"
}

# --- 内部函数 ---

# 直接通过 jq 重写配置中的 callers 数组
# 避免使用 caller clear/add（因为 clear 后 bash 自身会被拦截）
_write_callers() {
    need_cmd jq

    local uid gid
    uid=$(id -u)
    gid=$(id -g)

    local new_callers="[]"

    # fish
    if command -v fish &>/dev/null; then
        local fish_path
        fish_path="$(readlink -f "$(command -v fish)")"
        msg "  注册 fish: $fish_path"
        new_callers=$(echo "$new_callers" | jq \
            --arg p "$fish_path" --argjson u "$uid" --argjson g "$gid" \
            '. + [{"path": $p, "uid": $u, "gid": $g, "canonicalize": false}]')
    else
        warn "  fish 未找到，跳过"
    fi

    # git（libexec/git-core/git 是 git 凭据 helper 的实际调用者）
    if command -v git &>/dev/null; then
        local git_real git_root git_libexec git_path
        git_real="$(readlink -f "$(command -v git)")"
        git_root="$(dirname "$(dirname "$git_real")")"
        git_libexec="${git_root}/libexec/git-core/git"

        if [[ -e "$git_libexec" ]]; then
            git_path="$git_libexec"
        else
            git_path="$git_real"
        fi
        msg "  注册 git: $git_path"
        new_callers=$(echo "$new_callers" | jq \
            --arg p "$git_path" --argjson u "$uid" --argjson g "$gid" \
            '. + [{"path": $p, "uid": $u, "gid": $g, "canonicalize": false}]')
    else
        warn "  git 未找到，跳过"
    fi

    # 原子写入：先写临时文件再替换
    local tmp
    tmp="$(mktemp)"
    jq --argjson callers "$new_callers" '.callers = $callers' "$CONFIG_FILE" > "$tmp"
    mv "$tmp" "$CONFIG_FILE"
}

cmd_help() {
    cat <<EOF
keepassxc-credential-setup — 管理 git-credential-keepassxc 配置文件

用法: keepassxc-credential-setup <命令>

命令:
  status    检查配置健康状态（路径是否过期、是否与当前系统一致）
  init      初始化完整配置（databases + callers）
  update    检测并更新过期的 callers 路径
  callers   仅重新注册 callers（不影响 databases）
  help      显示此帮助信息

配置文件: $CONFIG_FILE
EOF
}

# --- 主入口 ---

case "$COMMAND" in
    status)  cmd_status  ;;
    init)    cmd_init    ;;
    update)  cmd_update  ;;
    callers) cmd_callers ;;
    help|--help|-h) cmd_help ;;
    *) die "未知命令: $COMMAND。运行 'keepassxc-credential-setup help' 查看用法。" ;;
esac
