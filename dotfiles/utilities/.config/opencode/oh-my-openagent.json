      "model": "zai-coding-plan/glm-5-turbo",
      "fallback_models": [
        "minimax-cn-coding-plan/MiniMax-M2.7",
        "zai-coding-plan/glm-4.7-flashx"
      ]
    },
    "unspecified-low": {
      "model": "zai-coding-plan/glm-4.7-flashx",
