{
  "$schema": "https://charm.land/crush.json",
  "tools": {
    "ls": {
      "max_depth": 6,
      "max_items": 400
    },
    "grep": {
      "timeout": 15
    }
  },
  "options": {
    "context_paths": [
      "~/.config/crush/context/01-language.md",
      "~/.config/crush/context/02-style.md",
      "~/.config/crush/context/03-shell-strategy.md",
      "~/.config/crush/context/04-workspace.md"
    ],
    "tui": {
      "compact_mode": true,
      "diff_mode": "split",
      "transparent": true,
      "completions": {
        "max_depth": 3,
        "max_items": 200
      }
    },
    "initialize_as": "AGENTS.md",
    "auto_lsp": true,
    "progress": true,
    "disable_notifications": false,
    "disable_provider_auto_update": false
  },
  "permissions": {
    "allowed_tools": [
      "view",
      "ls",
      "grep",
      "edit"
    ]
  },
  "providers": {
    "zhipu": {
      "id": "Zhipu",
      "name": "Zhipu Provider",
      "base_url": "https://open.bigmodel.cn/api/coding/paas/v4",
      "api_key": "$ZAI_API_KEY"
    }
  },
  "models": {
    "large": {
      "provider": "zhipu",
      "model": "glm-5.1",
      "think": true,
      "max_tokens": 65536
    },
    "small": {
      "provider": "minimax-china",
      "model": "MiniMax-M2.7",
      "max_tokens": 131072
    },
    "quick": {
      "provider": "zhipu",
      "model": "glm-4.7-flash",
      "max_tokens": 32768
    }
  },
  "lsp": {
    "c_cpp": {
      "command": "~/.guix-home/profile/bin/ccls",
      "filetypes": [
        "c",
        "cc",
        "cpp",
        "cxx",
        "h",
        "hpp"
      ],
      "root_markers": [
        ".ccls",
        "compile_commands.json",
        "compile_flags.txt",
        "CMakeLists.txt",
        "meson.build",
        "Makefile"
      ],
      "timeout": 30
    },
    "python": {
      "command": "~/.guix-home/profile/bin/pylsp",
      "filetypes": [
        "py"
      ],
      "root_markers": [
        "pyproject.toml",
        "setup.py",
        "setup.cfg",
        "requirements.txt",
        "uv.lock",
        ".venv"
      ],
      "options": {
        "pylsp": {
          "plugins": {
            "black": {
              "enabled": true
            },
            "pylsp_mypy": {
              "enabled": true,
              "live_mode": false
            },
            "rope": {
              "enabled": true
            },
            "pycodestyle": {
              "enabled": false
            },
            "mccabe": {
              "enabled": false
            },
            "pyflakes": {
              "enabled": false
            }
          }
        }
      },
      "timeout": 30
    },
    "rust": {
      "command": "~/.guix-home/profile/bin/rust-analyzer",
      "filetypes": [
        "rs"
      ],
      "root_markers": [
        "Cargo.toml",
        "rust-project.json"
      ],
      "timeout": 30
    },
    "java": {
      "command": "~/.guix-home/profile/bin/jdtls",
      "filetypes": [
        "java"
      ],
      "root_markers": [
        "pom.xml",
        "build.gradle",
        "build.gradle.kts",
        "settings.gradle",
        "settings.gradle.kts"
      ],
      "timeout": 60
    },
    "typescript": {
      "command": "~/.config/crush/bin/typescript-language-server",
      "args": [
        "--stdio"
      ],
      "filetypes": [
        "js",
        "jsx",
        "ts",
        "tsx"
      ],
      "root_markers": [
        "package.json",
        "tsconfig.json",
        "jsconfig.json",
        "deno.json",
        "deno.jsonc",
        "bun.lock",
        "pnpm-lock.yaml",
        "yarn.lock"
      ],
      "timeout": 60
    },
    "html": {
      "command": "~/.config/crush/bin/vscode-html-language-server",
      "args": [
        "--stdio"
      ],
      "filetypes": [
        "html",
        "htm"
      ],
      "root_markers": [
        "package.json",
        ".git"
      ],
      "timeout": 60
    },
    "css": {
      "command": "~/.config/crush/bin/vscode-css-language-server",
      "args": [
        "--stdio"
      ],
      "filetypes": [
        "css",
        "scss",
        "less"
      ],
      "root_markers": [
        "package.json",
        ".git"
      ],
      "timeout": 60
    },
    "json": {
      "command": "~/.config/crush/bin/vscode-json-language-server",
      "args": [
        "--stdio"
      ],
      "filetypes": [
        "json",
        "jsonc"
      ],
      "root_markers": [
        "package.json",
        ".git"
      ],
      "timeout": 60
    },
    "markdown": {
      "command": "~/.config/crush/bin/vscode-markdown-language-server",
      "args": [
        "--stdio"
      ],
      "filetypes": [
        "md",
        "markdown"
      ],
      "root_markers": [
        ".git"
      ],
      "timeout": 60
    },
    "eslint": {
      "command": "~/.config/crush/bin/vscode-eslint-language-server",
      "args": [
        "--stdio"
      ],
      "filetypes": [
        "js",
        "jsx",
        "ts",
        "tsx"
      ],
      "root_markers": [
        "package.json",
        ".eslintrc",
        ".eslintrc.json",
        ".eslintrc.js",
        "eslint.config.js",
        "eslint.config.mjs",
        "eslint.config.cjs",
        "eslint.config.ts"
      ],
      "timeout": 60
    },
    "bash": {
      "command": "~/.config/crush/bin/bash-language-server",
      "args": [
        "start"
      ],
      "filetypes": [
        "sh",
        "bash",
        "zsh"
      ],
      "root_markers": [
        ".git"
      ],
      "timeout": 60
    },
    "nix": {
      "disabled": true,
      "command": "nil",
      "filetypes": [
        "nix"
      ],
      "root_markers": [
        "flake.nix",
        "shell.nix",
        "default.nix"
      ],
      "timeout": 30
    },
    "zig": {
      "disabled": true,
      "command": "zls",
      "filetypes": [
        "zig"
      ],
      "root_markers": [
        "build.zig",
        "build.zig.zon"
      ],
      "timeout": 30
    },
    "kotlin": {
      "disabled": true,
      "command": "kotlin-language-server",
      "filetypes": [
        "kt",
        "kts"
      ],
      "root_markers": [
        "build.gradle",
        "build.gradle.kts",
        "settings.gradle",
        "settings.gradle.kts"
      ],
      "timeout": 60
    }
  },
  "mcp": {
    "context7": {
      "type": "stdio",
      "command": "~/.config/crush/bin/context7-mcp",
      "timeout": 45
    },
    "memory": {
      "type": "stdio",
      "command": "~/.config/crush/bin/mcp-server-memory",
      "timeout": 30
    },
    "sequential_thinking": {
      "type": "stdio",
      "command": "~/.config/crush/bin/mcp-server-sequential-thinking",
      "timeout": 30
    }
  }
}