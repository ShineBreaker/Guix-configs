#!/bin/bash
# 对齐显示的快捷键帮助
# 使用 display-popup 显示，所有内容在同一页面

# 显示帮助弹窗
tmux display-popup -E -w 83% -h 68% -b rounded \
  "printf '\n' && \
   printf '  ╔═══════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════╗\n' && \
   printf '  ║                                                                      TMUX 快捷键指南                                                                      ║\n' && \
   printf '  ╚═══════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════╝\n\n' && \
   printf '   ┌──────────────────────────────┐         ┌──────────────────────────────┐         ┌──────────────────────────────┐         ┌──────────────────────────────┐\n' && \
   printf '   │  基础操作                    │         │  窗格操作                    │         │  窗口操作                    │         │  复制模式                    │\n' && \
   printf '   ├──────────────────────────────┤         ├──────────────────────────────┤         ├──────────────────────────────┤         ├──────────────────────────────┤\n' && \
   printf '   │  Ctrl+x r   重新加载配置     │         │  Ctrl+x \\    垂直分屏        │         │  Ctrl+x c   新建窗口         │         │  Ctrl+x [   进入复制模式     │\n' && \
   printf '   │  Ctrl+x ?   显示此帮助       │         │  Ctrl+x -    水平分屏        │         │  Ctrl+x &   关闭当前窗口     │         │  Ctrl+x p   粘贴缓冲区内容   │\n' && \
   printf '   │  Ctrl+x d   分离当前会话     │         │  Ctrl+x hjkl vim 切换窗格    │         │  Ctrl+x n   下一个窗口       │         │  Ctrl+x #   列出缓冲区       │\n' && \
   printf '   │  Ctrl+x :   进入命令模式     │         │  Ctrl+x x    关闭当前窗格    │         │  Ctrl+x p   上一个窗口       │         │  v          开始选择         │\n' && \
   printf '   │  Ctrl+x s   选择会话         │         │  Ctrl+x !    拆分为窗口      │         │  Ctrl+x 0-9 切换到指定窗口   │         │  y          复制到剪贴板     │\n' && \
   printf '   │  Ctrl+x (   上一个会话       │         │  Ctrl+x z    最大化窗格      │         │  Ctrl+x ,   重命名窗口       │         │  Enter      复制并退出       │\n' && \
   printf '   │  Ctrl+x )   下一个会话       │         │  Ctrl+x q    显示窗格编号    │         │  Ctrl+x \$   重命名会话       │         │  Esc        退出复制模式     │\n' && \
   printf '   └──────────────────────────────┘         └──────────────────────────────┘         └──────────────────────────────┘         └──────────────────────────────┘\n' && \
   printf '   ┌──────────────────────────────┐         ┌──────────────────────────────┐         ┌──────────────────────────────┐         ┌──────────────────────────────┐\n' && \
   printf '   │  侧边栏                      │         │  布局                        │         │  调整大小                    │         │  搜索与 URL                  │\n' && \
   printf '   ├──────────────────────────────┤         ├──────────────────────────────┤         ├──────────────────────────────┤         ├──────────────────────────────┤\n' && \
   printf '   │  Ctrl+x B   切换侧边栏       │         │  Ctrl+x Space 切换布局       │         │  Ctrl+方向键 调整窗格大小    │         │  Ctrl+x /   搜索回滚         │\n' && \
   printf '   │  Ctrl+x f   模糊跳转窗口     │         │  Ctrl+x Alt+1 even-horiz     │         │  Ctrl+x r   进入调整模式     │         │  Ctrl+x H   打开回滚         │\n' && \
   printf '   │  Ctrl+x g   刷新 git 信息    │         │  Ctrl+x Alt+2 even-vert      │         │  方向键     在调整模式中使用 │         │  Ctrl+x F   搜索并高亮       │\n' && \
   printf '   │  Ctrl+x G   折叠/展开组      │         │  Ctrl+x Alt+3 main-horiz     │         │  Esc/q      退出调整模式     │         │  Ctrl+x URL 打开链接         │\n' && \
   printf '   │  Ctrl+x i   窗口详情         │         │  Ctrl+x Alt+4 main-vert      │         │  Ctrl+x {   当前窗格上移     │         │  Ctrl+x U   选择 URL         │\n' && \
   printf '   │  Ctrl+x T   设置侧栏标题     │         │  Ctrl+x Alt+5 tiled          │         │  Ctrl+x }   当前窗格下移     │         │  脚本功能                    │\n' && \
   printf '   │  Ctrl+x D   设置侧栏描述     │         │  Ctrl+x L   切换到上一个布局 │         │  Ctrl+x o   切换到下一个窗格 │         │  Ctrl+x W   工作区快照管理   │\n' && \
   printf '   └──────────────────────────────┘         └──────────────────────────────┘         └──────────────────────────────┘         └──────────────────────────────┘\n' && \
   printf '  ┌───────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────┐\n' && \
   printf '  │  快捷操作（无需前缀键）                                                                                                                                   │\n' && \
   printf '  ├───────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────┤\n' && \
   printf '  │  Alt+方向键 切换窗格 │ Ctrl+方向键 调整窗格大小 │ Alt+Shift+K/J 逐行滚动 │ Alt+Shift+Page 逐页滚动 │ Alt+Shift+Home/End 历史顶/底部 │ 鼠标滚轮 滚动历史   │\n' && \
   printf '  └───────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────┘\n\n' && \
   printf '  按任意键关闭此窗口...' && \
  read -n 1"
