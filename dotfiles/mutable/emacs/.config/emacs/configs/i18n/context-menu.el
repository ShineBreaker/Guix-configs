(defun custom/context-menu--translate-string (string)
  "翻译 STRING；未登记时返回原字符串。"
  (let* ((plain (substring-no-properties string))
         (translation (cdr (assoc plain custom:context-menu-label-translations))))
    (if (not translation)
        string
      (if (> (length string) 0)
          (apply #'propertize translation (text-properties-at 0 string))
        translation))))

(defun custom/context-menu--translate-object (object)
  "递归翻译 OBJECT 中的字符串。"
  (cond
   ((stringp object)
    (custom/context-menu--translate-string object))
   ((consp object)
    (mapcar #'custom/context-menu--translate-object object))
   (t object)))

(defun custom/context-menu--translate-menu-item (item)
  "翻译菜单项 ITEM 的标题和子菜单。"
  (when (and (consp item) (eq (car item) 'menu-item))
    (let ((label-cell (cdr item))
          (binding (nth 2 item))
          (properties (nthcdr 3 item)))
      (when label-cell
        (setcar label-cell
                (custom/context-menu--translate-object (car label-cell))))
      (when (keymapp binding)
        (custom/context-menu--translate-keymap binding))
      (while (consp properties)
        (when (and (eq (car properties) :help)
                   (consp (cdr properties)))
          (setcar (cdr properties)
                  (custom/context-menu--translate-object (cadr properties))))
        (setq properties (cddr properties))))))

(defun custom/context-menu--translate-keymap (keymap)
  "递归翻译 KEYMAP 内的菜单标题。"
  (when (keymapp keymap)
    (when (and (consp keymap)
               (eq (car-safe keymap) 'keymap)
               (stringp (cadr keymap)))
      (setcar (cdr keymap)
              (custom/context-menu--translate-string (cadr keymap))))
    (map-keymap
     (lambda (_event binding)
       (cond
        ((and (consp binding) (eq (car binding) 'menu-item))
         (custom/context-menu--translate-menu-item binding))
        ((keymapp binding)
         (custom/context-menu--translate-keymap binding))))
     keymap))
  keymap)

(defun custom/context-menu-translate (menu)
  "翻译 `context-menu-map' 返回的 MENU。"
  (custom/context-menu--translate-keymap menu))

(defun custom/context-menu--translate-generated-menu (menu)
  "翻译运行期生成的 MENU keymap。"
  (custom/context-menu--translate-keymap menu))

(defun custom/context-menu--with-generated-menu-translation (fn &rest args)
  "在调用 FN ARGS 期间翻译 `easy-menu-create-menu' 生成的 keymap。"
  (unwind-protect
      (progn
        (advice-add 'easy-menu-create-menu :filter-return
                    #'custom/context-menu--translate-generated-menu)
        (apply fn args))
    (advice-remove 'easy-menu-create-menu
                   #'custom/context-menu--translate-generated-menu)))

(defun custom/context-menu--enable-treemacs-i18n ()
  "为 Treemacs 右键菜单启用中文翻译。"
  (when (fboundp 'treemacs-rightclick-menu)
    (unless (advice-member-p #'custom/context-menu--with-generated-menu-translation
                             #'treemacs-rightclick-menu)
      (advice-add 'treemacs-rightclick-menu :around
                  #'custom/context-menu--with-generated-menu-translation))))

(when (fboundp 'context-menu-map)
  (unless (advice-member-p #'custom/context-menu-translate #'context-menu-map)
    (advice-add 'context-menu-map :filter-return #'custom/context-menu-translate)))

(custom/context-menu--enable-treemacs-i18n)
(with-eval-after-load 'treemacs-mouse-interface
  (custom/context-menu--enable-treemacs-i18n))

(with-eval-after-load 'magit-section
  (unless (advice-member-p #'custom/context-menu--translate-string
                           #'magit-menu-format-desc)
    (advice-add 'magit-menu-format-desc :filter-return
                #'custom/context-menu--translate-string)))

(provide 'context-menu-i18n)
