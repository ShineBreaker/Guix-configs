  (custom/which-key--flatten-specs nil custom:which-key-description-spec)
  "Which-key 全局中文描述映射表。")

(defvar custom:which-key-descriptions-applied nil
  "避免重复写入 `which-key-replacement-alist'。")

(defun custom/which-key-apply-descriptions ()
  "将中文描述注册到 `which-key'。"
  (when (and (featurep 'which-key)
             (not custom:which-key-descriptions-applied))
    (dolist (entry custom:which-key-regexp-replacements)
      (setq which-key-replacement-alist
            (append which-key-replacement-alist (list entry))))
    (dolist (entry custom:which-key-replacements)
      (which-key-add-key-based-replacements (car entry) (cdr entry)))
    (dolist (mode-entry custom:which-key-major-mode-description-spec)
      (let ((mode (car mode-entry))
            (specs (cdr mode-entry)))
        (dolist (entry (custom/which-key--flatten-specs nil specs))
          (which-key-add-major-mode-key-based-replacements
           mode (car entry) (cdr entry)))))
    (setq custom:which-key-descriptions-applied t)))

(with-eval-after-load 'which-key
  (custom/which-key-apply-descriptions))

(provide 'which-key-descriptions)
;;; which-key-descriptions.el ends here
