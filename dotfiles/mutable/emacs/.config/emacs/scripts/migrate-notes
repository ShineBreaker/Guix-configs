#!/usr/bin/env bash
# migrate-notes — 生成 notes/ 历史目录迁移清单(PLAN §2.1)
#
# notes/ 标记为历史迁移区,不再创建新文件。本脚本只生成清单(dry-run 默认),
# 由用户 review 后决定具体迁移动作:迁入 Org-roam / inbox / agenda / 只读归档。
#
# 数据安全策略:
#   - 默认 dry-run,不移动任何文件
#   - --apply 才真正执行移动,且只对清单中明确分类的文件生效
#   - 纯备份内容默认移到 archive/(只读,不加入 agenda/Roam DB/Dashboard)
#   - 不删除任何源文件(由用户 review 后手工清理)
#
# 用法:
#   scripts/migrate-notes                 # 生成清单到 stdout
#   scripts/migrate-notes --apply         # 执行清单中的移动
#   scripts/migrate-notes --help
#
# 退出码:0=成功;1=参数错误;2=notes/ 不存在

set -euo pipefail

NOTES_DIR="${LITERAL_ORG_NOTES_DIR:-$HOME/Documents/Org/notes}"
ROAM_DIR="${LITERAL_ORG_ROAM_DIR:-$HOME/Documents/Org/roam}"
INBOX_FILE="${LITERAL_ORG_INBOX_FILE:-$HOME/Documents/Org/inbox.org}"
ARCHIVE_DIR="${LITERAL_ORG_ARCHIVE_DIR:-$HOME/Documents/Org/archive/notes-legacy}"
APPLY=0

usage() {
    cat <<'EOF'
migrate-notes — notes/ 历史目录迁移清单生成器(PLAN §2.1)

环境变量(可选):
  LITERAL_ORG_NOTES_DIR    notes/ 源目录(默认 ~/Documents/Org/notes)
  LITERAL_ORG_ROAM_DIR     Roam 目标目录(默认 ~/Documents/Org/roam)
  LITERAL_ORG_INBOX_FILE   inbox.org 路径(默认 ~/Documents/Org/inbox.org)
  LITERAL_ORG_ARCHIVE_DIR  只读归档目录(默认 ~/Documents/Org/archive/notes-legacy)

用法:
  scripts/migrate-notes          生成迁移清单(dry-run)
  scripts/migrate-notes --apply  执行迁移
  scripts/migrate-notes --help   显示本帮助
EOF
}

for arg in "$@"; do
    case "$arg" in
        --apply) APPLY=1 ;;
        --help|-h) usage; exit 0 ;;
        *) echo "错误: 未知参数 $arg" >&2; usage; exit 1 ;;
    esac
done

if [[ ! -d "$NOTES_DIR" ]]; then
    echo "错误: notes/ 目录不存在: $NOTES_DIR" >&2
    exit 2
fi

# 分类启发式:基于标题 / 内容判断文件性质
# 分类输出格式: "<category>\t<file>\t<reason>"
classify_file() {
    local file="$1"
    local base
    base="$(basename "$file" .org)"

    # 从文件第一个 * 标题判断
    local heading
    heading="$(awk '/^\*+ / { sub(/^*+ /, ""); print; exit }' "$file" 2>/dev/null || echo "")"

    # 启发式规则(可由用户 review 后调整):
    # 1. TODO / 任务关键词 → agenda
    if grep -qE '^\*+ (TODO|NEXT|INPROGRESS|WAITING|DONE|CANCELLED)\b' "$file" 2>/dev/null; then
        echo -e "agenda\t$file\t包含 TODO/状态关键词"
        return
    fi

    # 2. DEADLINE/SCHEDULED → agenda
    if grep -qE '(DEADLINE|SCHEDULED):' "$file" 2>/dev/null; then
        echo -e "agenda\t$file\t包含 DEADLINE/SCHEDULED"
        return
    fi

    # 3. 有 :ROAM_REFS: / 双向链接 → roam
    if grep -qE ':ROAM_REFS:|\[\[id:' "$file" 2>/dev/null; then
        echo -e "roam\t$file\t含 Roam 属性或 id 链接"
        return
    fi

    # 4. 短文件(<500 字符,一句话草稿风格) → inbox
    local size
    size="$(wc -c <"$file" 2>/dev/null || echo 0)"
    if (( size < 500 )); then
        echo -e "inbox\t$file\t短文件(草稿候选, $size 字符)"
        return
    fi

    # 5. 默认 → 只读归档
    echo -e "archive\t$file\t无明显结构,默认只读归档"
}

echo "=== notes/ 迁移清单 ==="
echo "源目录: $NOTES_DIR"
echo "模式:   $([[ $APPLY -eq 1 ]] && echo 'APPLY (执行)' || echo 'DRY-RUN (预览)')"
echo

declare -a categories=(agenda roam inbox archive)
declare -A counts=([agenda]=0 [roam]=0 [inbox]=0 [archive]=0)

# 收集清单
declare -a agenda_files roam_files inbox_files archive_files
while IFS= read -r file; do
    [[ -z "$file" ]] && continue
    while IFS=$'\t' read -r category f reason; do
        [[ -z "$category" ]] && continue
        counts[$category]=$((counts[$category] + 1))
        case "$category" in
            agenda)  agenda_files+=("$f") ;;
            roam)    roam_files+=("$f") ;;
            inbox)   inbox_files+=("$f") ;;
            archive) archive_files+=("$f") ;;
        esac
        echo "[$category] $(basename "$f")  ($reason)"
    done < <(classify_file "$file")
done < <(find "$NOTES_DIR" -type f -name '*.org' | sort)

echo
echo "=== 汇总 ==="
for cat in "${categories[@]}"; do
    echo "  $cat: ${counts[$cat]} 个文件"
done
echo

if [[ $APPLY -eq 0 ]]; then
    echo "DRY-RUN: 未执行任何操作。review 后用 --apply 执行迁移。"
    exit 0
fi

# --apply 执行
echo "=== 执行迁移 ==="

mkdir -p "$ROAM_DIR" "$ARCHIVE_DIR"
# inbox 文件需要追加,不创建新文件
touch "$INBOX_FILE"

migrate_one() {
    local category="$1" file="$2"
    local base
    base="$(basename "$file")"

    case "$category" in
        agenda|roam)
            local target
            target="$ROAM_DIR/$base"
            # 避免覆盖:加 .migrated-<timestamp> 后缀
            if [[ -e "$target" ]]; then
                target="$ROAM_DIR/${base%.org}.migrated-$(date +%Y%m%d-%H%M%S).org"
            fi
            mv -v "$file" "$target"
            ;;
        inbox)
            # 追加到 inbox.org 末尾作为新 subtree
            {
                echo ""
                echo "* TODO 迁移自 notes/$base"
                echo ":PROPERTIES:"
                echo ":CREATED: $(date '+[%Y-%m-%d %a]')"
                echo ":END:"
                echo ""
                cat "$file"
                echo ""
            } >> "$INBOX_FILE"
            echo "  追加到 inbox.org: $base"
            rm -v "$file"
            ;;
        archive)
            local target
            target="$ARCHIVE_DIR/$base"
            if [[ -e "$target" ]]; then
                target="$ARCHIVE_DIR/${base%.org}.archived-$(date +%Y%m%d-%H%M%S).org"
            fi
            mv -v "$file" "$target"
            ;;
    esac
}

for f in "${agenda_files[@]:-}"; do [[ -n "$f" ]] && migrate_one agenda "$f"; done
for f in "${roam_files[@]:-}";     do [[ -n "$f" ]] && migrate_one roam   "$f"; done
for f in "${inbox_files[@]:-}";    do [[ -n "$f" ]] && migrate_one inbox  "$f"; done
for f in "${archive_files[@]:-}";  do [[ -n "$f" ]] && migrate_one archive "$f"; done

echo
echo "迁移完成。源文件已移动(agenda/roam/archive)或合并(inbox)。"
echo "下一步:运行 `agenote reindex` 重建知识库索引。"
