#!/usr/bin/env bash
set -euo pipefail

root="$(cd "$(dirname "$0")/.." && pwd)"
lock="/tmp/literal-config-configctl-${UID}.lock"
status_file="$(mktemp /tmp/literal-configctl-status.XXXXXX)"
export LITERAL_CONFIGCTL_STATUS_FILE="$status_file"
printf '1' >"$status_file"

flock -x "$lock" emacs --batch -Q --script "$root/scripts/configctl.el" "$@"
emacs_status=$?
status="$(<"$status_file")"
rm -f "$status_file"

if [[ "$status" =~ ^[0-9]+$ ]]; then
    exit "$status"
fi
exit "$emacs_status"
