{
  "$schema": "https://raw.githubusercontent.com/code-yeongyu/oh-my-openagent/dev/assets/oh-my-opencode.schema.json",

  // ============================================================
  // Agent-Model Matching Config (zai-coding-plan only)
  // 所有模型均使用 zai-coding-plan 提供商
  // GLM-5.1 作为通信/编排/深度推理主力模型
  // GLM-4.7 / GLM-4.5-air 作为轻量工具型模型
  // ============================================================

  "agents": {

    // === 通信型 → GLM 家族 ===

    "sisyphus": {
      "model": "zhipuai-coding-plan/glm-5.1",
      "ultrawork": {
        "model": "zhipuai-coding-plan/glm-5.1"
      },
      "fallback_models": [
        "zhipuai-coding-plan/glm-5",
        "zhipuai-coding-plan/glm-5-turbo"
      ]
    },

    "metis": {
      "model": "zhipuai-coding-plan/glm-5.1",
      "fallback_models": [
        "zhipuai-coding-plan/glm-5",
        "zhipuai-coding-plan/glm-5-turbo"
      ]
    },

    // === 双提示词型 ===

    "prometheus": {
      "model": "zhipuai-coding-plan/glm-5.1",
      "fallback_models": [
        "zhipuai-coding-plan/glm-5",
        "zhipuai-coding-plan/glm-5-turbo"
      ]
    },

    "atlas": {
      "model": "zhipuai-coding-plan/glm-5-turbo",
      "fallback_models": [
        "zhipuai-coding-plan/glm-5",
        "zhipuai-coding-plan/glm-4.7"
      ]
    },

    // === 深度专家型 ===

    "hephaestus": {
      "model": "zhipuai-coding-plan/glm-5.1",
      "fallback_models": [
        "zhipuai-coding-plan/glm-5",
        "zhipuai-coding-plan/glm-4.7"
      ]
    },

    "oracle": {
      "model": "zhipuai-coding-plan/glm-5.1",
      "fallback_models": [
        "zhipuai-coding-plan/glm-5",
        "zhipuai-coding-plan/glm-5-turbo"
      ]
    },

    "momus": {
      "model": "zhipuai-coding-plan/glm-5.1",
      "fallback_models": [
        "zhipuai-coding-plan/glm-5",
        "zhipuai-coding-plan/glm-5-turbo"
      ]
    },

    // === 工具型 → 速度优先 ===

    "explore": {
      "model": "zhipuai-coding-plan/glm-4.7",
      "fallback_models": [
        "zhipuai-coding-plan/glm-4.5-air"
      ]
    },

    "librarian": {
      "model": "zhipuai-coding-plan/glm-4.7",
      "fallback_models": [
        "zhipuai-coding-plan/glm-4.5-air"
      ]
    },

    "multimodal-looker": {
      "model": "zhipuai-coding-plan/glm-4.6v",
      "fallback_models": [
        "zhipuai-coding-plan/glm-5v-turbo",
        "zhipuai-coding-plan/glm-4.5v"
      ]
    },

    "sisyphus-junior": {
      "model": "zhipuai-coding-plan/glm-5.1",
      "fallback_models": [
        "zhipuai-coding-plan/glm-4.7",
        "zhipuai-coding-plan/glm-4.5-air"
      ]
    }
  },

  "categories": {

    "visual-engineering": {
      "model": "zhipuai-coding-plan/glm-5.1",
      "fallback_models": [
        "zhipuai-coding-plan/glm-5",
        "zhipuai-coding-plan/glm-5-turbo"
      ]
    },

    "ultrabrain": {
      "model": "zhipuai-coding-plan/glm-5.1",
      "fallback_models": [
        "zhipuai-coding-plan/glm-5",
        "zhipuai-coding-plan/glm-5-turbo"
      ]
    },

    "deep": {
      "model": "zhipuai-coding-plan/glm-5.1",
      "fallback_models": [
        "zhipuai-coding-plan/glm-5",
        "zhipuai-coding-plan/glm-5-turbo"
      ]
    },

    "artistry": {
      "model": "zhipuai-coding-plan/glm-5.1",
      "fallback_models": [
        "zhipuai-coding-plan/glm-5",
        "zhipuai-coding-plan/glm-5-turbo"
      ]
    },

    "quick": {
      "model": "zhipuai-coding-plan/glm-4.5-air",
      "fallback_models": [
        "zhipuai-coding-plan/glm-4.7"
      ]
    },

    "unspecified-high": {
      "model": "zhipuai-coding-plan/glm-5.1",
      "fallback_models": [
        "zhipuai-coding-plan/glm-5",
        "zhipuai-coding-plan/glm-5-turbo",
        "zhipuai-coding-plan/glm-4.7"
      ]
    },

    "unspecified-low": {
      "model": "zhipuai-coding-plan/glm-4.7",
      "fallback_models": [
        "zhipuai-coding-plan/glm-4.5-air"
      ]
    },

    "writing": {
      "model": "zhipuai-coding-plan/glm-5",
      "fallback_models": [
        "zhipuai-coding-plan/glm-4.7"
      ]
    }
  },

  "background_task": {
    "providerConcurrency": {
      "zai-coding-plan": 20
    },
    "modelConcurrency": {
      "zhipuai-coding-plan/glm-5.1": 5,
      "zhipuai-coding-plan/glm-5": 5,
      "zhipuai-coding-plan/glm-5-turbo": 5,
      "zhipuai-coding-plan/glm-4.7": 10,
      "zhipuai-coding-plan/glm-4.5-air": 20
    }
  }
}