{
  "defaultProvider": "opencode-go",
  "defaultModel": "kimi-k2.6",
  "defaultThinkingLevel": "high",
  "npmCommand": [
    "bun"
  ],
  "compaction": {
    "enabled": true,
    "reserveTokens": 16384,
    "keepRecentTokens": 20000
  },
  "retry": {
    "enabled": true,
    "maxRetries": 3,
    "baseDelayMs": 2000,
    "provider": {
      "maxRetryDelayMs": 60000
    }
  },
  "packages": [
    "npm:context-mode",
    "npm:pi-subagents",
    "npm:pi-mcp-adapter",
    "npm:pi-web-access",
    "npm:@plannotator/pi-extension",
    "npm:pi-powerline-footer",
    "npm:pi-hashline-edit",
    "npm:pi-lens",
    "npm:@ff-labs/pi-fff",
    "npm:pi-cache-graph",
    "npm:@juicesharp/rpiv-todo",
    "npm:@juicesharp/rpiv-advisor",
    "npm:@juicesharp/rpiv-btw",
    "npm:@tmustier/pi-ralph-wiggum",
    "npm:pi-context-prune"
  ],
  "extensions": [
    "./*"
  ],
  "skills": [
    "./skills/*"
  ],
  "modelRouter": {
    "quick-edit": "deepseek/deepseek-v4-flash",
    "research": "deepseek/deepseek-v4-pro",
    "deep": "zhipu/glm-5.1",
    "writing": "deepseek/deepseek-v4-flash"
  },
  "modelFallback": {
    "zhipu/glm-5.1": [
      "opencode-go/deepseek-v4-pro",
      "deepseek/deepseek-v4-pro",
      "opencode-go/deepseek-v4-flash",
      "deepseek/deepseek-v4-flash"
    ],
    "deepseek-v4-pro": [
      "opencode-go/deepseek-v4-pro",
      "deepseek/deepseek-v4-flash",
      "opencode-go/deepseek-v4-flash"
    ]
  },
  "subagents": {
    "parallel": {
      "maxTasks": 8,
      "concurrency": 4
    },
    "agentOverrides": {
      "scout": {
        "model": "opencode-go/deepseek-v4-flash",
        "thinking": "low",
        "inheritProjectContext": true,
        "inheritSkills": false
      },
      "researcher": {
        "model": "opencode-go/deepseek-v4-pro",
        "thinking": "medium"
      },
      "oracle": {
        "model": "zhipu/glm-5.1",
        "inheritProjectContext": true,
        "inheritSkills": false
      },
      "delegate": {
        "model": "opencode-go/deepseek-v4-pro",
        "inheritProjectContext": true,
        "inheritSkills": false
      },
      "context-builder": {
        "model": "zhipu/glm-5.1",
        "inheritProjectContext": true,
        "inheritSkills": false
      }
    }
  },
  "powerline": {
    "preset": "default",
    "path": {
      "mode": "abbreviated"
    }
  },
  "todoEnforcer": {
    "enabled": true
  },
  "ralphLoop": {
    "enabled": true,
    "maxIterations": 20
  },
  "lastChangelogVersion": "0.75.3",
  "images": {
    "blockImages": true
  },
  "theme": "light",
  "showHardwareCursor": false,
  "transport": "auto",
  "collapseChangelog": true,
  "quietStartup": true,
  "globalContext": {
    "contextDir": "/home/brokenshine/.config/agents/context",
    "extraFiles": [
      "/home/brokenshine/Documents/Org/profile.org"
    ]
  }
}