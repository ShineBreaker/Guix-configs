# stow-local-ignore for stow/pi — Perl regex, one per line, matched against
# the tail of the relative path within the package. See GNU Stow manual,
# "Ignore Lists" section. Blank lines and `#` comments are allowed.
#
# Source-of-truth rationale: pi/.gitignore (kept verbatim below) already
# excludes node_modules / .pnpm-store. We add a few more runtime/derived
# artifacts so `--no-folding` never symlinks them into ~/.config/pi or
# ~/.local/share/pi.

# --- from upstream pi/.gitignore ---
node_modules$
\.pnpm-store$

# --- additional runtime / cache artifacts ---
# NOTE: npm/pnpm-lock.yaml 不排除——它随 stow 部署，让 pi-update 的
# bootstrap_extensions_package 能从 lockfile 读取精确版本号生成 package.json。
# sessions / db files written by the pi runtime under ~/.config/pi
# (uncomment if you want to also skip them; currently we keep the dir empty
#  and let pi recreate it on first run)
# sessions/.*\.db(-shm|-wal)?$
# terminal-sessions/.*\.log$
# models\.db(-shm|-wal)?$

# --- extensions: skip generated __pycache__ if any TS/Python tooling
#     under extensions/ ever produces one ---
extensions/.*(__pycache__|.*\.pyc)$

# --- docs: AGENTS.md / README.md are maintainer-facing, not runtime config.
#     pi only loads *.ts extension files; skip the markdown so `--no-folding`
#     doesn't symlink them into ~/.config/pi. ---
extensions/.*AGENTS\.md$

# --- extensions submodules: skip their .git gitlink files so
#     `--no-folding` doesn't symlink submodule metadata into ~/.config/pi.
#     Matches the emacs submodule convention (stow/emacs also ignores .git). ---
\.git$