{
  "defaultProvider": "minimax-cn",
  "defaultModel": "MiniMax-M3",
  "npmCommand": [
    "pnpm"
  ],
  "compaction": {
    "enabled": true,
    "reserveTokens": 16384,
    "keepRecentTokens": 20000
  },
  "retry": {
    "enabled": true,
    "maxRetries": 3,
    "baseDelayMs": 2000,
    "provider": {
      "maxRetryDelayMs": 60000
    }
  },
  "packages": [
    "npm:context-mode",
    "npm:pi-mcp-adapter",
    "npm:pi-web-access",
    "npm:@plannotator/pi-extension",
    "npm:pi-powerline-footer",
    "npm:pi-hashline-edit",
    "npm:pi-lens",
    "npm:@ff-labs/pi-fff",
    "npm:pi-cache-graph",
    "npm:@juicesharp/rpiv-todo",
    "npm:@juicesharp/rpiv-btw",
    "npm:@juicesharp/rpiv-ask-user-question"
  ],
  "skills": [
    "~/.config/agents/skills/*"
  ],
  "powerline": {
    "preset": "default",
    "path": {
      "mode": "abbreviated"
    }
  },
  "atelier": {
    "pollIntervalMs": 2000,
    "panePrefix": "sub:",
    "keepResults": 24,
    "timeoutMs": 1800000,
    "maxTasks": 8,
    "maxConcurrency": 4,
    "defaultTier": "pro",
    "tiers": {
      "ultra": {
        "model": "zai/GLM-5.1",
        "fallback": ["minimax-cn/MiniMax-M3"]
      },
      "pro": {
        "model": "minimax-cn/MiniMax-M3",
        "fallback": ["deepseek/deepseek-v4-pro", "zai/GLM-4.7"]
      },
      "quick": {
        "model": "deepseek/deepseek-v4-flash",
        "fallback": ["minimax-cn/MiniMax-M2.7"]
      },
      "visual": {
        "model": "xiaomi/mimo-v2.5",
        "fallback": ["minimax-cn/MiniMax-M3"]
      }
    }
  },
  "globalContext": {
    "enabled": true,
    "contextDir": "$XDG_CONFIG_HOME/agents/context",
    "extraFiles": [
      "$HOME/Documents/Org/MEMORY.org"
    ],
    "maxFiles": 8,
    "maxBytesPerFile": 65536,
    "maxTotalBytes": 196608
  },
  "lastChangelogVersion": "0.75.5",
  "images": {
    "blockImages": false
  },
  "theme": "dark",
  "showHardwareCursor": false,
  "transport": "auto",
  "collapseChangelog": true,
  "quietStartup": true,
  "defaultThinkingLevel": "xhigh"
}