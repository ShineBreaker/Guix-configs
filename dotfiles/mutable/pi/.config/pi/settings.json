{
  "defaultProvider": "zai",
  "defaultModel": "GLM-5.1",
  "defaultThinkingLevel": "high",
  "npmCommand": [
    "bun"
  ],
  "compaction": {
    "enabled": true,
    "reserveTokens": 16384,
    "keepRecentTokens": 20000
  },
  "retry": {
    "enabled": true,
    "maxRetries": 3,
    "baseDelayMs": 2000,
    "provider": {
      "maxRetryDelayMs": 60000
    }
  },
  "packages": [
    "npm:context-mode",
    "npm:pi-mcp-adapter",
    "npm:pi-web-access",
    "npm:@plannotator/pi-extension",
    "npm:pi-powerline-footer",
    "npm:pi-hashline-edit",
    "npm:pi-lens",
    "npm:@ff-labs/pi-fff",
    "npm:pi-cache-graph",
    "npm:@juicesharp/rpiv-todo",
    "npm:@juicesharp/rpiv-advisor",
    "npm:@juicesharp/rpiv-btw",
    "npm:@tmustier/pi-ralph-wiggum"
  ],
  "skills": [
    "./skills/*"
  ],

  "powerline": {
    "preset": "default",
    "path": {
      "mode": "abbreviated"
    }
  },
  "tmuxSubagents": {
    "pollIntervalMs": 2000,
    "panePrefix": "sub:",
    "keepResults": 24
  },
  "globalContext": {
    "contextDir": "/home/brokenshine/.config/agents/context",
    "extraFiles": [
      "/home/brokenshine/Documents/Org/profile.org"
    ]
  },

  "lastChangelogVersion": "0.75.4",
  "images": {
    "blockImages": true
  },
  "theme": "dark",
  "showHardwareCursor": false,
  "transport": "auto",
  "collapseChangelog": true,
  "quietStartup": true
}
