{
  "defaultProvider": "deepseek",
  "defaultModel": "deepseek-v4-pro",
  "npmCommand": [
    "bun"
  ],
  "compaction": {
    "enabled": true,
    "reserveTokens": 16384,
    "keepRecentTokens": 20000
  },
  "retry": {
    "enabled": true,
    "maxRetries": 3,
    "baseDelayMs": 2000,
    "provider": {
      "maxRetryDelayMs": 60000
    }
  },
  "packages": [
    "npm:context-mode",
    "npm:pi-mcp-adapter",
    "npm:pi-web-access",
    "npm:@plannotator/pi-extension",
    "npm:pi-powerline-footer",
    "npm:pi-hashline-edit",
    "npm:pi-lens",
    "npm:@ff-labs/pi-fff",
    "npm:pi-cache-graph",
    "npm:@juicesharp/rpiv-todo",
    "npm:@juicesharp/rpiv-advisor",
    "npm:@juicesharp/rpiv-btw",
    "npm:@tmustier/pi-ralph-wiggum"
  ],
  "skills": [
    "~/.config/agents/skills/*"
  ],
  "powerline": {
    "preset": "default",
    "path": {
      "mode": "abbreviated"
    }
  },
  "tmuxSubagents": {
    "pollIntervalMs": 2000,
    "panePrefix": "sub:",
    "keepResults": 24,
    "timeoutMs": 1800000,
    "maxTasks": 8,
    "maxConcurrency": 4
  },
  "globalContext": {
    "enabled": true,
    "contextDir": "$XDG_CONFIG_HOME/agents/context",
    "extraFiles": [
      "$HOME/Documents/Org/profile.org"
    ],
    "maxFiles": 8,
    "maxBytesPerFile": 65536,
    "maxTotalBytes": 196608
  },
  "lastChangelogVersion": "0.75.4",
  "images": {
    "blockImages": true
  },
  "theme": "dark",
  "showHardwareCursor": false,
  "transport": "auto",
  "collapseChangelog": true,
  "quietStartup": true,
  "defaultThinkingLevel": "high"
}