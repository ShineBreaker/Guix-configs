#!/usr/bin/env bash
# SPDX-FileCopyrightText: 2026 BrokenShine <xchai404@gmail.com>
#
# SPDX-License-Identifier: MIT
#
# pi-update — 更新 Pi 核心 + 扩展到最新版本
#
# 设计原则：
#   1. settings.json 的 packages 数组是扩展清单的单一真相源
#   2. package.json 是派生产物，不手维护
#   3. 用 pnpm update --latest 确保跨 minor/major 版本升级
#      （pnpm update 不带 --latest 只在 semver range 内更新）
#   4. 扩展目录用 nodeLinker=hoisted（pnpm-workspace.yaml），
#      否则 jiti 从 symlink 路径解析模块时找不到传递依赖。
set -euo pipefail

# === 路径 ===
PI_DATA_DIR="${PI_LOCAL_ROOT:-${XDG_DATA_HOME:-${HOME}/.local/share}/pi}"
PI_CONFIG_DIR="${PI_CODING_AGENT_DIR:-${XDG_CONFIG_HOME:-${HOME}/.config}/pi}"
EXT_DIR="${PI_CONFIG_DIR}/npm"
SETTINGS_FILE="${PI_CONFIG_DIR}/settings.json"
PI_BIN="${PI_DATA_DIR}/node_modules/.bin/pi"

# 缺了任一 binding 会导致 pi 启动崩溃
NATIVE_PKGS=(better-sqlite3 koffi)

# 不应自动移除的核心/框架包（settings.json 未列出时保留）
PROTECTED_PKGS=(pi-subagents)

# 顶层声明：--extensions-only 模式跳过 native rebuild 时，
# FAILED 数组仍已声明，set -u 下引用 ${#FAILED[@]} 安全
FAILED=()

# --extensions-only: 首次安装时由 pi 脚本调用，只装扩展、跳过核心更新和 native rebuild
EXTENSIONS_ONLY=0
if [[ "${1:-}" == "--extensions-only" ]]; then
	EXTENSIONS_ONLY=1
	shift
fi

# === 工具函数 ===

read_pi_version() {
	node -p "require('${PI_DATA_DIR}/node_modules/@earendil-works/pi-coding-agent/package.json').version" 2>/dev/null || echo '未知'
}

# pnpm 10+ 的配置位置从 package.json 的 pnpm 字段迁移到 pnpm-workspace.yaml。
# 扩展目录还需要 nodeLinker=hoisted，否则 jiti 从 symlink 路径解析模块时
# 找不到扩展的传递依赖（如 @ff-labs/pi-fff 依赖 @ff-labs/fff-node）。
ensure_pnpm_workspace() {
	local dir="$1" ext_only="$2"
	local wsfile="$dir/pnpm-workspace.yaml"
	if [[ -f "$wsfile" ]]; then
		# 确保已有文件包含 nodeLinker（可能由旧版 pi-update 创建，缺失此行）
		if [[ "$ext_only" == "yes" ]] && ! grep -q 'nodeLinker' "$wsfile"; then
			echo "nodeLinker: hoisted" | cat - "$wsfile" >"$wsfile.tmp" && mv "$wsfile.tmp" "$wsfile"
		fi
		return 0
	fi

	if [[ "$ext_only" == "yes" ]]; then
		cat >"$wsfile" <<'EOF'
nodeLinker: hoisted
EOF
	else
		# 核心目录不需要 hoisted，但 pnpm 11 需要此文件来管理 allowBuilds
		: >"$wsfile"
	fi
}

# 清除 package.json 中废弃的 pnpm 字段（pnpm 10+ 已废弃，每次运行报 WARN）
strip_deprecated_pnpm_field() {
	local pkgfile="$1"
	[[ -f "$pkgfile" ]] || return 0
	node -e '
		const fs = require("fs");
		const [f] = process.argv.slice(1);
		const pkg = JSON.parse(fs.readFileSync(f, "utf8"));
		if (pkg.pnpm) {
			delete pkg.pnpm;
			fs.writeFileSync(f, JSON.stringify(pkg, null, 2) + "\n");
		}
	' "$pkgfile" || true
}

# === 核心更新：用 --latest 强制跨版本升级 ===
update_latest() {
	local dir="$1" label="$2" is_ext="$3"
	ensure_pnpm_workspace "$dir" "$is_ext"
	strip_deprecated_pnpm_field "$dir/package.json"

	local out
	if out=$(cd "$dir" && pnpm update --latest 2>&1); then
		echo "$out"
		return 0
	fi

	# ERR_PNPM_IGNORED_BUILDS: 包已正常安装，只是 build scripts 未审批 — 非致命
	if echo "$out" | grep -q 'ERR_PNPM_IGNORED_BUILDS'; then
		echo "$out" | grep -v 'ERR_PNPM_IGNORED_BUILDS' | grep -v 'approve-builds'
		echo "  [${label}] 部分依赖需审批 build scripts（非致命）"
		return 0
	fi

	# 其他错误（store 冲突、lockfile 损坏等）：删 lockfile 重装
	echo "$out" >&2
	echo "  [${label}] pnpm update --latest 失败，清除 lockfile 重装..." >&2
	(cd "$dir" && rm -f pnpm-lock.yaml && CI=true pnpm install --no-frozen-lockfile 2>&1)
}

# === 扩展包清单同步（settings.json → package.json） ===
sync_extensions_from_settings() {
	[[ -f "$SETTINGS_FILE" ]] || {
		echo "  settings.json 不存在，跳过" >&2
		return 0
	}

	# package.json 不存在时创建空壳。
	if [[ ! -f "$EXT_DIR/package.json" ]]; then
		mkdir -p "$EXT_DIR"
		echo '{"name":"pi-extensions","private":true,"type":"module","dependencies":{}}' \
			> "$EXT_DIR/package.json"
		echo "  package.json 缺失，已创建空壳" >&2
	fi

	local diff
	diff=$(node -e '
		const fs = require("fs");
		const [settingsFile, pkgFile, ...protect] = process.argv.slice(1);
		const cfg = JSON.parse(fs.readFileSync(settingsFile, "utf8"));
		const pkg = JSON.parse(fs.readFileSync(pkgFile, "utf8"));

		const desired = (cfg.packages || [])
			.filter(p => p.startsWith("npm:"))
			.map(p => p.slice(4));
		const current = Object.keys(pkg.dependencies || {});

		const add = desired.filter(p => !current.includes(p));
		const rem = current.filter(p =>
			!desired.includes(p) &&
			!p.startsWith("@earendil-works/") &&
			!protect.includes(p)
		);

		if (add.length) process.stdout.write("add:" + add.join(" ") + "\n");
		if (rem.length) process.stdout.write("remove:" + rem.join(" ") + "\n");
	' "$SETTINGS_FILE" "$EXT_DIR/package.json" "${PROTECTED_PKGS[@]}")

	if [[ -z "$diff" ]]; then
		echo "  无需变更"
		return 0
	fi

	while IFS= read -r line; do
		case "$line" in
		add:*)
			local pkgs="${line#add:}"
			echo "  安装: ${pkgs}"
			(cd "$EXT_DIR" && pnpm add ${pkgs} 2>&1)
			;;
		remove:*)
			local pkgs="${line#remove:}"
			echo "  移除: ${pkgs}"
			(cd "$EXT_DIR" && pnpm remove ${pkgs} 2>&1)
			;;
		esac
	done <<<"$diff"
}

# === native binding 重建与验证 ===
rebuild_native_bindings() {
	echo "重建 native binding..."
	shopt -s nullglob
	for pkg in "${NATIVE_PKGS[@]}"; do
		printf "  %s ... " "$pkg"
		if ! (cd "$EXT_DIR" && pnpm rebuild "$pkg" >/dev/null 2>&1); then
			echo "rebuild 失败"
			FAILED+=("$pkg")
			continue
		fi
		# hoisted 模式下包直接在 node_modules 顶层；isolated 模式在 .pnpm 下。
		# 用通配兼顾两种布局。
		local found=0
		for d in "$EXT_DIR/node_modules/${pkg}" \
		         "$EXT_DIR/node_modules/.pnpm/${pkg//\//+}@*"; do
			if find "$d" -name '*.node' 2>/dev/null | grep -q .; then
				found=1
				break
			fi
		done
		if [[ $found -eq 1 ]]; then
			echo "OK"
		else
			echo "binding 缺失!"
			FAILED+=("$pkg")
		fi
	done
	shopt -u nullglob
}

# === main ===

if ! command -v pnpm &>/dev/null; then
	echo "pnpm is not installed." >&2
	exit 1
fi

if [[ ! -x "$PI_BIN" ]]; then
	echo "Pi 核心未安装，执行首次安装..." >&2
	(cd "$PI_DATA_DIR" && CI=true pnpm install --no-frozen-lockfile)
fi

echo "当前版本: $(read_pi_version)"

if [[ $EXTENSIONS_ONLY -eq 0 ]]; then
	echo "更新 Pi 核心..."
	update_latest "$PI_DATA_DIR" "Pi 核心" "no"
fi

echo "同步扩展包（依据 settings.json）..."
sync_extensions_from_settings

echo "更新扩展..."
update_latest "$EXT_DIR" "扩展" "yes"

if [[ $EXTENSIONS_ONLY -eq 0 ]]; then
	rebuild_native_bindings
fi

echo ""
echo "更新后: $(read_pi_version)"
if [[ ${#FAILED[@]} -gt 0 ]]; then
	echo "失败: ${FAILED[*]}" >&2
	exit 1
fi
echo "提示: 已运行的 pi 进程仍用旧版本,需重启 pi 加载新代码"
