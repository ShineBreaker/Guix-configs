#!/usr/bin/env bash
set -euo pipefail

resolve_script_path() {
  local source="${BASH_SOURCE[0]}"
  while [[ -L "${source}" ]]; do
    local dir
    dir="$(cd -P "$(dirname "${source}")" && pwd)"
    source="$(readlink "${source}")"
    [[ "${source}" != /* ]] && source="${dir}/${source}"
  done
  cd -P "$(dirname "${source}")" && pwd
}

ensure_installed() {
  local xdg_data_home="${XDG_DATA_HOME:-${HOME}/.local/share}"
  local pi_root="${PI_LOCAL_ROOT:-${xdg_data_home}/pi}"

  if [[ -x "${pi_root}/node_modules/.bin/pi" ]]; then
    cd "${pi_root}" && pwd
    return 0
  fi

  if ! command -v bun &>/dev/null; then
    echo "bun is not installed. Please install bun first." >&2
    return 1
  fi

  if [[ ! -d "${pi_root}" ]]; then
    echo "Pi local root not found at ${pi_root}." >&2
    return 1
  fi

  echo "Installing Pi dependencies..." >&2
  cd "${pi_root}" && bun install

  local config_dir="${PI_CODING_AGENT_DIR:-${XDG_CONFIG_HOME:-${HOME}/.config}/pi}"
  local npm_dir="${config_dir}/npm"
  if [[ -f "${npm_dir}/package.json" ]]; then
    echo "Installing agent plugins..." >&2
    cd "${npm_dir}" && bun install
  fi

}

SCRIPT_DIR="$(resolve_script_path)"
ROOT_DIR="$(ensure_installed)"

cd "${ROOT_DIR}"

echo "=========================================="
echo "Pi Agent 更新"
echo "位置: ${ROOT_DIR}"
echo "=========================================="

echo ""
echo "[1/4] 当前版本:"
"${ROOT_DIR}/node_modules/.bin/pi" --version 2>/dev/null || echo "  无法获取版本号"

echo ""
echo "[2/4] 更新核心依赖..."
deps=$(node -e "console.log(Object.keys(require('./package.json').dependencies).join(' '))")
for dep in ${deps}; do
  echo "  更新 ${dep}..."
  bun install "${dep}@latest"
done

echo ""
echo "[3/4] 更新扩展包..."
NPM_DIR="${PI_CODING_AGENT_DIR:-${XDG_CONFIG_HOME:-${HOME}/.config}/pi}/npm"
if [[ -f "${NPM_DIR}/package.json" ]]; then
  cd "${NPM_DIR}"
  ext_deps=$(node -e "console.log(Object.keys(require('./package.json').dependencies).join(' '))")
  for dep in ${ext_deps}; do
    echo "  更新 ${dep}..."
    bun install "${dep}@latest"
  done
else
  echo "  未找到扩展包配置"
fi

cd "${ROOT_DIR}"
echo ""
echo "[4/4] 验证更新:"
echo "  pi 版本: $("${ROOT_DIR}/node_modules/.bin/pi" --version 2>/dev/null || echo '未知')"

echo ""
CONFIG_DIR="${PI_CODING_AGENT_DIR:-${XDG_CONFIG_HOME:-${HOME}/.config}/pi}"
echo "配置目录状态:"
echo "  扩展: $(ls -1 "${CONFIG_DIR}/extensions/" 2>/dev/null | wc -l) 个"
echo "  子代理: $(ls -1 "${CONFIG_DIR}/agents/" 2>/dev/null | wc -l) 个"
echo "  提示模板: $(ls -1 "${CONFIG_DIR}/prompts/" 2>/dev/null | wc -l) 个"

echo ""
echo "=========================================="
echo "更新完成"
echo "=========================================="
