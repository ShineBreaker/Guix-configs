#!/usr/bin/env bash
set -euo pipefail

XDG_DATA_HOME="${XDG_DATA_HOME:-${HOME}/.local/share}"
RUNTIME="${PI_RUNTIME_HELPER:-${XDG_DATA_HOME}/pi/scripts/pi-xdg-runtime.sh}"

if [[ ! -r "${RUNTIME}" ]]; then
  echo "Pi runtime helper not found: ${RUNTIME}" >&2
  exit 1
fi

# shellcheck source=/dev/null
source "${RUNTIME}"

ROOT_DIR="$(pi_ensure_installed)"
pi_prepare_compat_tree

cd "${ROOT_DIR}"

echo "=========================================="
echo "Pi Agent 更新"
echo "位置: ${ROOT_DIR}"
echo "=========================================="

echo ""
echo "[1/4] 当前版本:"
"${ROOT_DIR}/node_modules/.bin/pi" --version 2>/dev/null || echo "  无法获取版本号"

echo ""
echo "[2/4] 更新核心依赖..."
deps=$(node -e "console.log(Object.keys(require('./package.json').dependencies).join(' '))")
for dep in ${deps}; do
  echo "  更新 ${dep}..."
  bun install "${dep}@latest"
done

echo ""
echo "[3/4] 更新扩展包..."
NPM_DIR="${PI_DATA_DIR}/npm"
if [[ -f "${NPM_DIR}/package.json" ]]; then
  cd "${NPM_DIR}"
  ext_deps=$(node -e "console.log(Object.keys(require('./package.json').dependencies).join(' '))")
  for dep in ${ext_deps}; do
    echo "  更新 ${dep}..."
    bun install "${dep}@latest"
  done
else
  echo "  未找到扩展包配置"
fi

cd "${ROOT_DIR}"
echo ""
echo "[4/4] 验证更新:"
echo "  pi 版本: $("${ROOT_DIR}/node_modules/.bin/pi" --version 2>/dev/null || echo '未知')"

echo ""
CONFIG_DIR="${PI_CONFIG_DIR}"
echo "配置目录状态:"
echo "  扩展: $(ls -1 "${CONFIG_DIR}/extensions/" 2>/dev/null | wc -l) 个"
echo "  子代理: $(ls -1 "${CONFIG_DIR}/agents/" 2>/dev/null | wc -l) 个"
echo "  提示模板: $(ls -1 "${CONFIG_DIR}/prompts/" 2>/dev/null | wc -l) 个"

echo ""
echo "=========================================="
echo "更新完成"
echo "=========================================="
