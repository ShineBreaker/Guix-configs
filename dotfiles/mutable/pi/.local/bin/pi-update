#!/usr/bin/env bash
# SPDX-FileCopyrightText: 2026 BrokenShine <xchai404@gmail.com>
#
# SPDX-License-Identifier: MIT
set -euo pipefail

PI_DATA_DIR="${PI_LOCAL_ROOT:-${XDG_DATA_HOME:-${HOME}/.local/share}/pi}"
EXT_DIR="${PI_CODING_AGENT_DIR:-${XDG_CONFIG_HOME:-${HOME}/.config}/pi}/npm"
PI_BIN="${PI_DATA_DIR}/node_modules/.bin/pi"

# 缺了任一 binding 会导致 pi 启动崩溃
NATIVE_PKGS=(better-sqlite3 koffi)

if ! command -v pnpm &>/dev/null; then
	echo "pnpm is not installed." >&2
	exit 1
fi

if [[ ! -x "${PI_BIN}" ]]; then
	echo "Pi core not installed at ${PI_DATA_DIR}; running pnpm install first..." >&2
	(cd "${PI_DATA_DIR}" && CI=true pnpm install --no-frozen-lockfile)
fi

if [[ ! -f "${EXT_DIR}/package.json" ]]; then
	echo "Pi extensions not configured at ${EXT_DIR}" >&2
	exit 1
fi

read_pi_version() {
	node -p "require('${PI_DATA_DIR}/node_modules/@earendil-works/pi-coding-agent/package.json').version" 2>/dev/null || echo '未知'
}

# pnpm 11 以 ERR_PNPM_IGNORED_BUILDS 退出码 1 标记未审批的 build scripts，
# 但包本身已正常安装。只对真正的 store 冲突或解析失败走重装。
pnpm_update_or_reinstall() {
	local dir="$1" label="$2"
	local out
	out=$(cd "${dir}" && pnpm update 2>&1) || {
		if echo "${out}" | grep -q 'ERR_PNPM_UNEXPECTED_STORE'; then
			echo "[${label}] store 版本不兼容，重新安装..." >&2
			(cd "${dir}" && CI=true pnpm install --no-frozen-lockfile 2>&1)
		elif echo "${out}" | grep -q 'ERR_PNPM_IGNORED_BUILDS'; then
			echo "${out}" | grep -v 'ERR_PNPM_IGNORED_BUILDS' | grep -v 'Run "pnpm approve-builds"'
			echo "[${label}] 部分依赖需要审批 build scripts（非致命）"
		else
			echo "${out}"
			echo "[${label}] pnpm update 失败，重新安装..." >&2
			(cd "${dir}" && CI=true pnpm install --no-frozen-lockfile 2>&1)
		fi
		return
	}
	echo "${out}"
}

echo "当前版本: $(read_pi_version)"

echo "更新 Pi 核心..."
pnpm_update_or_reinstall "${PI_DATA_DIR}" "Pi 核心"

echo "更新扩展..."
pnpm_update_or_reinstall "${EXT_DIR}" "扩展"

# prebuild-install 偶发 silent 失败; 强制 rebuild + 验证 binding 实际存在
echo "重建 native binding..."
shopt -s nullglob
FAILED=()
for pkg in "${NATIVE_PKGS[@]}"; do
	printf "  %s ... " "${pkg}"
	if ! (cd "${EXT_DIR}" && pnpm rebuild "${pkg}" >/dev/null 2>&1); then
		echo "rebuild 失败"
		FAILED+=("${pkg}")
		continue
	fi
	# pnpm 把 / 转成 + (@google/genai -> @google+genai), 用通配找 .node
	pnpm_name="${pkg//\//+}"
	found=0
	for d in "${EXT_DIR}/node_modules/.pnpm/${pnpm_name}@"*; do
		if find "$d" -name '*.node' 2>/dev/null | grep -q .; then
			found=1
			break
		fi
	done
	if [[ $found -eq 1 ]]; then
		echo "OK"
	else
		echo "binding 缺失!"
		FAILED+=("${pkg}")
	fi
done

echo ""
echo "更新后: $(read_pi_version)"
if [[ ${#FAILED[@]} -gt 0 ]]; then
	echo "失败: ${FAILED[*]}" >&2
	exit 1
fi
echo "提示: 已运行的 pi 进程仍用旧版本,需重启 pi 加载新代码"
