#!/usr/bin/env bash
# SPDX-FileCopyrightText: 2026 BrokenShine <xchai404@gmail.com>
#
# SPDX-License-Identifier: MIT
set -euo pipefail

PI_DATA_DIR="${PI_LOCAL_ROOT:-${XDG_DATA_HOME:-${HOME}/.local/share}/pi}"

export PI_HOME="${PI_CODING_AGENT_DIR:-${XDG_CONFIG_HOME:-${HOME}/.config}/pi}"
export PI_CODING_AGENT_DIR="${PI_HOME}"
export PI_CODING_AGENT_SESSION_DIR="${PI_CODING_AGENT_SESSION_DIR:-${PI_DATA_DIR}/sessions}"
export PI_OFFLINE="${PI_OFFLINE:-1}"

BIN="${PI_DATA_DIR}/node_modules/.bin/pi"

if [[ ! -x "${BIN}" ]]; then
	if ! command -v pnpm &>/dev/null; then
		echo "pnpm is not installed." >&2; exit 1
	fi
	echo "Installing Pi dependencies..." >&2
	cd "${PI_DATA_DIR}" && pnpm install
fi

echo "=========================================="
echo "Pi Agent 更新"
echo "=========================================="

echo ""
echo "[1/3] 当前版本:"
"${BIN}" --version 2>/dev/null || echo "  无法获取版本号"

echo ""
echo "[2/3] 更新核心依赖..."
cd "${PI_DATA_DIR}" && pnpm update

echo ""
echo "[3/3] 更新扩展包..."
NPM_DIR="${PI_DATA_DIR}/npm"
if [[ -f "${NPM_DIR}/package.json" ]]; then
	cd "${NPM_DIR}" && pnpm update
else
	echo "  未找到扩展包配置"
fi

echo ""
echo "验证: $("${BIN}" --version 2>/dev/null || echo '未知')"
echo ""
echo "=========================================="
echo "更新完成"
echo "=========================================="
