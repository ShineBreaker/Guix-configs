set -euo pipefail

XDG_DATA_HOME="${XDG_DATA_HOME:-${HOME}/.local/share}"
RUNTIME="${PI_RUNTIME_HELPER:-${XDG_DATA_HOME}/pi/scripts/pi-xdg-runtime.sh}"

if [[ ! -r "${RUNTIME}" ]]; then
	echo "Pi runtime helper not found: ${RUNTIME}" >&2
	exit 1
fi

# shellcheck source=/dev/null
source "${RUNTIME}"

# Export PI_* and XDG_* into the current shell before exec so the Pi
# process inherits them.  pi_ensure_installed runs in a subshell and would
# not propagate its exports.
pi_init_xdg

pi_ensure_installed >/dev/null

BIN_DIR="${PI_DATA_DIR}/node_modules/.bin"

export PATH="${BIN_DIR}:${PATH}"

exec "${BIN_DIR}/pi" "$@"
